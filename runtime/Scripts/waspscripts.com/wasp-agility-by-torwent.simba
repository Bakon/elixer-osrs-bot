type
  TAgility = record(TBaseWalkerScript)
    AgilityCourse:
      record
        Level: Int32;
        Steps: T2DPointArray;
        Obstacles: TGameObjectArray;

        MarkOfGraceArray: TGroundItemArray;
        MOGSteps: TIntegerArray;

        PortalArray: TGameObjectArray;
      end;

    Position: TPoint;
    CourseStep: Int32;
    CurrentHP: Int32;

    Obstacle: TGameObject;
    MarkOfGrace: TGroundItem;
    Portal: TGameObject;

    AgilityLevel: Int32;

    AlchValue: Int32;
    MarkValue: Int32;

    AlchItem: TItem;
  end;

//Setup Antiban override. Will add some extra antiban features to our script aside from what's built in, in WaspLib.
procedure TAntiban.Setup(); override;
begin
  Self.Skills := [ESKILL.AGILITY, ESKILL.TOTAL];
  Self.MinZoom := 0;
  Self.MaxZoom := 30;

  inherited;
end;

//Setup a common obstacle template.
procedure TGameObject.SeTGameObject(objUpText: TStringArray; coordinates: TPointArray; shape: Vector3);
begin
  Self := [];
  Self.SetupEx(shape, coordinates);
  Self.SetupUpText(objUpText);

  Filter := [True, False, True, True];
end;

