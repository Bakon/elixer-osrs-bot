procedure Tscript.assignmode;
var
  CurrentThievingLvl: integer;
begin
  writeln('Checking mode');
  CurrentThievingLvl := stats.getlevel(ersskill.thieving);
  if CurrentThievingLvl >= 2 then
    mode := 1;
  if CurrentThievingLvl >= 20 then
    mode := 2;
  if CurrentThievingLvl >= 35 then
    mode := 3;
  if CurrentThievingLvl >= 42 then
    mode := 4;
  if CurrentThievingLvl >= 50 then
    mode := 5;
  if CurrentThievingLvl >= 65 then
    mode := 6;
  if CurrentThievingLvl >= 75 then
    mode := 7;
  if CurrentThievingLvl >= 82 then
    mode := 8;
  if CurrentThievingLvl >= 87 then
    mode := 9;
  Writeln('Assigning mode: ',mode);
  self.loadmodeinfo;
end;
procedure TScript.Antiban_CheckThievinglvl();
var
  info: TRSSkillInfo;
begin
  Antiban.DebugLn('Checking thieving lvl');
  wait(1000,2000);
  Stats.getlevel(ersskill.thieving,false);
  if UpdateMode then
    self.assignmode;
  wait(1000,2000);

end;
procedure TScript.SetupAntiban();
begin
  Antiban.AddTask((ONE_MINUTE * 1) * Self.ABTimeMod, @ antiban.randommouse);
  Antiban.AddTask((ONE_MINUTE * 2) * Self.ABTimeMod, @ antiban.RandomRightClick);
  Antiban.AddTask((ONE_MINUTE * 4) * Self.ABTimeMod, @ antiban.HoverSkills);
  Antiban.AddTask((ONE_MINUTE * 5) * Self.ABTimeMod, @ Self.Antiban_CheckThievinglvl);
  Antiban.AddTask((ONE_MINUTE * 6) * Self.ABTimeMod, @ antiban.HoverMSItems);
  Antiban.AddTask((ONE_MINUTE * 7) * Self.ABTimeMod, @ antiban.randomrotate);
  Antiban.AddTask((ONE_MINUTE * 8) * Self.ABTimeMod, @ antiban.hovermsnpcs);
  Antiban.AddTask((ONE_MINUTE * 10) * Self.ABTimeMod, @ antiban.RandomTab);
end;
procedure Tscript.init();
var
  z: Int32;
begin
  ClearDebug();
  RSClient.Image.Clear();
  writeln(SRL.TimeStamp(), 'Initializing');
  if (not RSClient.IsLoggedIn()) then
    Login.LoginPlayer();
  Mouse.Speed := random(30, 35);
  Mouse.Gravity := random(15, 20);
  Mouse.MissChance := 0;
  Mouse.Wind := random(0, 2);
  Mouse.Distribution := MOUSE_DISTRIBUTION_GAUSS;
  xpbar.setup;
  XPBar.EarnedXP;
  xpbar.totalearnedxp(true);
  WL.GameSettings.MouseWheel := False;
  Antiban.MinZoom := 10;
  Antiban.MaxZoom := 15;
  Antiban.Skills := [ERSSkill.THIEVING, ersskill.SAILING, ERSSkill.TOTAL];
  ABTimeMod := Random(1, 3);
  Self.Action_Limit := StrToInt(Config.GetString('Antiban_MaxActions'));
  Self.ShutdownTime := StrToInt(Config.GetString('Antiban_MaxTime')) * ONE_MINUTE;
  Self.ActionsDone := 0;
  Self.SetupAntiban();
  ActivityTime.Start();
  Self.TrueRunTime.Start();
  Self.ActiveRunTime.Start();
  Self.worldlist := login.getplayer.worlds;

  // Initialize jail timer
  if Self.JailInterval > 0 then
