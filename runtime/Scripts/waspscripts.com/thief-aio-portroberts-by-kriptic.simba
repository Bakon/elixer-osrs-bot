function TScript.GetState(): EState;
begin
  RSClient.Image.Clear();
  //if RSClient.IsLoggedIn() and (ChatButtons.GetState(ERSChatButton.GAME_CHAT) <> ERSChatButtonState.ENABLED) then
  //  Exit(EState.CHANGE_CHAT_FILTER);
  if ActivityTime.elapsedTime > 300000 then
    Terminatescript('Inactivity detected');
  //if not ChatButtons.IsActive(ERSChatButton.GAME_CHAT) then
  //  Exit(EState.OPEN_CHAT);
  if InRange(Chat.GetScrollPosition, 1, 99) then
    Chat.SetScrollPosition(100);
  if Chat.LeveledUp() then
    Exit(EState.LEVEL_UP);
  if RSInterface.IsOpen() then
  begin
    if Bank.IsOpen() then
    begin
    end;
    Bank.Close(True);
  end;
  MyPos := Map.position;
  if self.injail then
    Exit(Estate.EscapeJail);
  if timer.elapsedtime > 300000 then
    forceresync := true;
  if inventory.isfull then
    Exit(Estate.EmptyInventory);
  if freshstart then
    exit(Estate.FreshStart);
  if ForceReSync then
    Exit(Estate.ForceReSync);
  if not inventory.isfull then
    Exit(Estate.StallRob);
  Writeln('End of get state');
  //antiban.randomrotate;
  terminatescript("end of states");
end;

procedure Tscript.run()
begin
  repeat
    LoginIfNot();
    Self.State := Self.GetState();
    writeln(SRL.TimeStamp(), "Current state :", self.getstate);
    case Self.State of
      EState.OPEN_CHAT: ChatButtons.Open(ERSChatButton.GAME_CHAT);
      EState.CHANGE_CHAT_FILTER: ChatButtons.ChangeState(ERSChatButton.GAME_CHAT, ERSChatButtonState.ENABLED);
      EState.LEVEL_UP: Chat.HandleLevelUp();
      Estate.EmptyInventory: self.handle_inventory;
      EState.StallRob: self.Assign_Stall_Handler;
      Estate.Freshstart: self.Handle_FreshStart;
      Estate.ForceReSync: self.Handle_Resync;
      Estate.EscapeJail: self.Handle_EscapeJail;
    end;
  until 1 = 0;
  //(Self.ActionsDone >= Self.Action_Limit);
  Logout.ClickLogout();
end;

begin
  if (not FileExists(AppPath + '\Resources\PortRobertStallGUI.png')) then
    DownloadToFile('https://i.imgur.com/BuGyVHV.png', AppPath + '\Resources\PortRobertStallGUI.png');
  Config.Setup(AppPath + 'Configs' + DirectorySeparator + 'PortRoberts.json');
  MyListHandler._Init(Config);
  ScriptGUI.Run();
  Bot.Init();
  Bot.Run();
end.




