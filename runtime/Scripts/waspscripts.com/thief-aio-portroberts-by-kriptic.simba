  Stats.Setup();
  stats.getlevel(ersskill.thieving, false);
  SetupObjectCache(GemS, [1.5, 1.2, 8], [[3382, 37276]], 'Gem', '', [CTS2(8558749, 7, 0.08, 0.58) {,CTS2(7900563, 20, 0.23, 0.35)}]);
