  SetupObjectCache(VegS, [1.5, 1.2, 8], [[3362, 37244]], 'Veg', '', [CTS2(8558749, 7, 0.08, 0.58) {,CTS2(7900563, 20, 0.23, 0.35)}]);
  SetupObjectCache(CannonballS, [1.5, 1.2, 8], [[3374, 37244]], 'Cannonball', '', [CTS2(8558749, 7, 0.08, 0.58) {,CTS2(7900563, 20, 0.23, 0.35)}]);
  SetupObjectCache(FurS, [1.2, 1.5, 8], [[3386, 37264]], 'Fur', '', [CTS2(8558749, 7, 0.08, 0.58) {,CTS2(7900563, 20, 0.23, 0.35)}]);
  SetupObjectCache(SilkS, [1.2, 1.5, 8], [[3386, 37252]], 'Silk', '', [CTS2(8558749, 7, 0.08, 0.58) {,CTS2(7900563, 20, 0.23, 0.35)}]);
