function TTool.GetCount(): Int32;
begin
  if Self.IsStackable then
    Result := Inventory.CountItemStack(Self.Item)
  else
    Result := Inventory.CountItem(Self.Item);
end;

function TRSWalker.GetTrapMS(Loc: TPoint; Height:Double=0; Offx,Offy:Double=0): TRectangle;
var
  angle: Double;
  vec: Vector3;
begin
  Loc   := Minimap.Center + (Loc - Self.GetMyPos());
  angle := Minimap.GetCompassAngle(False);
  vec   := Vec3(Loc.X,loc.Y).RotateXY(angle, Minimap.Center.X, Minimap.Center.Y);
  Result := Minimap.VectorToMSRect(vec + [-offx, -offy, Height], 2.2, 2.7, angle);
end;

function TRSWalker.MakePointVisible(p: TPoint): Boolean; override;
begin
  Exit(False);
  if p = Default(TPoint) then;
end;

procedure TAntiban.DoLoseFocus();
var
  t: Int32 := SRL.NormalRange(500, 2250);
begin
  Self.DebugLn(ToStr('Losing focus for: ', t, ' ms'));
  Self.LoseFocus(t);
end;

function TAntiban.HasTaskWaiting(): Boolean;
var
  i: Int32;
begin
  for i := 0 to High(Self.Tasks) do
    if Self.Tasks[i].Countdown.IsFinished() then
      Exit(True);
end;

procedure TQuetzalInterface.Init();
begin
  Self.DTMString := 'mwQAAAHic42RgYOhgZGBoAOJOIO4H4olA3AfE7UDcCMTNQOzOAMHWQGwPxG5AHADEgUDsDxXrmjCZITbMES8mBjASgeEAAE55ELA=';
end;

function TQuetzalInterface.IsOpen(): Boolean;
var
  dtmm, x, y: Int32;
begin
  dtmm := DTMFromString(Self.DTMString);
  try
    Result := FindDTM(dtmm, x, y, Mainscreen.Bounds);
  finally
    FreeDTM(dtmm);
  end;
end;

function TQuetzalInterface.Travel(Destination: EQuetzalSite): Boolean;
var
  dtmm, x, y: Int32;
begin
  Result := False;

  if not Self.IsOpen() then
    Exit(False);

  Mouse.Move(QUETZAL_DATA[Destination].Bounds, True);

  if WaitUntil(Mainscreen.GetUpText().ToLower().Contains(QUETZAL_DATA[Destination].UpText), 250, 2000) then
  begin
    Mouse.Click(MOUSE_LEFT);

    dtmm := DTMFromString(Self.DTMString);
    try
      Result := WaitUntil(not FindDTM(dtmm, x, y, Mainscreen.Bounds), 250, 3000);
    finally
      FreeDTM(dtmm);
    end;

    if WaitUntil(Chat.GetChat().Contains('destination yet'), 500, 5500) then
      Exit(False);
  end;
end;

procedure THunterGUI.StartScript(Sender: TObject); override;
const
  PATH = 'Configs/hunter.ini';
var
  sl, ml: String;
  bf, ba: Int32;
begin
  bf := Self.edit_BreakFor.GetText().ExtractInteger();
  ba := Self.edit_BreakAfter.GetText().ExtractInteger();

  if bf and ba then
    Antiban.AddBreak(ba * ONE_MINUTE, bf * ONE_MINUTE, 0.3, 1);

  if Self.cb_BlockInput.IsChecked() then
  begin
    WLSettings.RemoteInput.BlockInput := True;
    RSClient.RemoteInput.DisableRealInput();
  end else
  begin
    WLSettings.RemoteInput.BlockInput := False;
    RSClient.RemoteInput.EnableRealInput();
  end;

  if Self.cb_Sleeps.IsChecked() then
    Antiban.AddSleep('00:00:00', 7 * ONE_HOUR, 0.2, 1);

  if Self.combo_SunlightMeat.GetText() = 'Drop' then
    Junk += 'Raw sunlight antelope';

  if Self.combo_MoonlightMeat.GetText() = 'Drop' then
    Junk += 'Raw moonlight antelope';

  if Self.combo_SunlightAntlers.GetVisible() then
    sl := Self.combo_SunlightAntlers.GetText().ToLower();

  if Self.combo_MoonlightAntlers.GetVisible() then
    ml := Self.combo_MoonlightAntlers.GetText().ToLower();

  if sl.Contains('fletch') then
    Antlers += 'Sunlight antelope antler'
  else if sl.Contains('drop') then
    Junk += 'Sunlight antelope antler';

  if ml.Contains('fletch') then
    Antlers += 'Moonlight antelope antler'
  else if ml.Contains('drop') then
    Junk += 'Moonlight antelope antler';

  CutAntlers := Length(Antlers) > 0;

  if Self.cb_BankMoths.GetVisible() then
    BankMoths := Self.cb_BankMoths.IsChecked();

  if Self.cb_OuterFortis.GetVisible() then
    OuterFortis := Self.cb_Outerfortis.isChecked();

  if Self.combo_Whistle.GetVisible() then
  begin
    if Self.combo_Whistle.GetText() <> 'None' then
    begin
      UseWhistle := True;
      Whistle := Self.combo_Whistle.GetText();
    end else
      UseWhistle := False;
  end;

  if Self.combo_Pouch.GetVisible() then
  begin
    if Self.combo_Pouch.GetText() <> 'None' then
    begin
      UsePouch := True;
      Pouch := Self.combo_Pouch.GetText();
    end else
      UsePouch := False;
  end;

  FoodAmount := Self.combo_FoodAmount.GetText().ExtractInteger();
  Burying := Self.cb_BuryBones.IsChecked();
  Food := Self.combo_Food.GetText();
  Mode := EMode(Self.combo_Mode.GetItemIndex());

  WriteINI('Hunter', 'BreakAfter', Self.edit_BreakAfter.GetText(), PATH);
  WriteINI('Hunter', 'BreakFor', Self.edit_BreakFor.GetText(), PATH);
  WriteINI('Hunter', 'BlockInput', BoolToStr(Self.cb_BlockInput.IsChecked(), 'true', 'false'), PATH);
  WriteINI('Hunter', 'Mode', ToStr(Self.combo_Mode.GetItemIndex()), PATH);
  WriteINI('Hunter', 'BankMoths', BoolToStr(Self.cb_BankMoths.IsChecked(), 'true', 'false'), PATH);
  WriteINI('Hunter', 'Sleeps', BoolToStr(Self.cb_Sleeps.IsChecked(), 'true', 'false'), PATH);
  WriteINI('Hunter', 'OuterFortis', BoolToStr(Self.cb_OuterFortis.IsChecked(), 'true', 'false'), PATH);
  WriteINI('Hunter', 'Whistle', ToStr(Self.combo_Whistle.GetItemIndex()), PATH);
  WriteINI('Hunter', 'Pouch', ToStr(Self.combo_Pouch.GetItemIndex()), PATH);
  WriteINI('Hunter', 'BuryBones', BoolToStr(Self.cb_BuryBones.IsChecked(), 'true', 'false'), PATH);
  WriteINI('Hunter', 'Food', ToStr(Self.combo_Food.GetItemIndex()), PATH);
  WriteINI('Hunter', 'FoodAmount', ToStr(Self.combo_FoodAmount.GetItemIndex()), PATH);
  WriteINI('Hunter', 'SunlightAntlers', ToStr(Self.combo_SunlightAntlers.GetItemIndex()), PATH);
  WriteINI('Hunter', 'SunlightMeat', ToStr(Self.combo_SunlightMeat.GetItemIndex()), PATH);
  WriteINI('Hunter', 'MoonlightAntlers', ToStr(Self.combo_MoonlightAntlers.GetItemIndex()), PATH);
  WriteINI('Hunter', 'MoonlightMeat', ToStr(Self.combo_MoonlightMeat.GetItemIndex()), PATH);

  inherited;
end;

procedure THunterGUI.ShowChoreTab();
var
  Tab: TTabsheet := Self.GetTab('Chores');
begin
  if Tab <> nil then
    Tab.setTabVisible(True);
end;

procedure THunterGUI.HideChoreTab();
var
  Tab: TTabsheet := Self.GetTab('Chores');
begin
  if Tab <> nil then
  begin
    Tab.setTabVisible(False);
    FarmRunner.Enabled := False;
    BirdhouseRunner.Enabled := False;
  end;
end;

procedure THunterGUI.OnHunterCheckboxChanged(sender: TObject);
begin
  if Sender = nil then;
  Self.UpdateVisibility();
end;

procedure THunterGUI.UpdateVisibility();
var
  M: EMode := EMode(Self.combo_Mode.GetItemIndex());
  IsRumour, IsSunlight, IsMoonlight, IsMothBanker, ModeAllowsChores, HasWhistle: Boolean;
begin
  IsRumour     := (M = EMode.RUMOURS);
  IsSunlight   := (M = EMode.SUNLIGHT_ANTELOPES);
  IsMoonlight  := (M = EMode.MOONLIGHT_ANTELOPES);
  IsMothBanker := (M = EMode.MOONLIGHT_MOTHS);

  Self.combo_Food.SetVisible(M in [EMode.RUMOURS, EMode.SUNLIGHT_ANTELOPES, EMode.MOONLIGHT_ANTELOPES]);
  Self.combo_FoodAmount.SetVisible(Self.combo_Food.GetVisible());

  Self.combo_SunlightMeat.SetVisible(IsRumour or IsSunlight);
  Self.combo_SunlightAntlers.SetVisible(IsRumour or IsSunlight);
  Self.lab_Sunlight.SetVisible(IsRumour or IsSunlight);

  Self.cb_OuterFortis.SetVisible(IsRumour or IsSunlight);

  Self.combo_MoonlightMeat.SetVisible(IsRumour or IsMoonlight);
  Self.combo_MoonlightAntlers.SetVisible(IsRumour or IsMoonlight);
  Self.lab_Moonlight.SetVisible(IsRumour or IsMoonlight);

  Self.combo_Pouch.SetVisible(IsRumour or IsSunlight or IsMoonlight);

  Self.cb_BuryBones.SetVisible(IsRumour or IsSunlight or IsMoonlight);
  Self.cb_BankMoths.SetVisible(IsMothBanker);

  ModeAllowsChores := (M in [EMode.RUMOURS, EMode.SUNLIGHT_ANTELOPES, EMode.MOONLIGHT_ANTELOPES])
                      or (IsMothBanker and Self.cb_BankMoths.IsChecked());

  HasWhistle := (Self.combo_Whistle.GetText() <> 'None');

  if ModeAllowsChores and HasWhistle then
    Self.ShowChoreTab()
  else
    Self.HideChoreTab();

  Self.combo_Whistle.SetVisible((M in [EMode.RUMOURS, EMode.SUNLIGHT_ANTELOPES, EMode.MOONLIGHT_ANTELOPES]) or BirdhouseRunner.Enabled or FarmRunner.Enabled or (IsMothBanker and Self.cb_BankMoths.IsChecked()));
end;

procedure THunterGUI.OnTabChanged(Sender: TObject);
begin
  if Sender = nil then;
  Self.UpdateVisibility();
end;

procedure THunterGUI.ModeComboboxOnChange(Sender: TObject);
begin
  if Sender = nil then;
  Self.UpdateVisibility();
end;

procedure THunterGUI.WhistleComboboxOnChange(Sender: TObject);
begin
  if Sender = nil then;
  Self.UpdateVisibility();
end;

procedure THunterGUI.CreateCombo(var Cb: TLabeledCombobox; Parent: TControl; Cap: String; X, Y, W: Int32; Items: TStringArray; DefaultIdx: Int32);
begin
  Cb.Create(Parent);
  Cb.SetCaption(Cap);
  Cb.SetLeft(TControl.AdjustToDPI(X));
  Cb.SetTop(TControl.AdjustToDPI(Y));
  Cb.SetWidth(TControl.AdjustToDPI(W));
  Cb.AddItemArray(Items);
  Cb.SetItemIndex(DefaultIdx);
end;

procedure THunterGUI.CreateCheck(var Ck: TLabeledCheckbox; Parent: TControl; Cap: String; X, Y: Int32);
begin
  Ck.Create(Parent);
  Ck.SetCaption(Cap);
  Ck.SetLeft(TControl.AdjustToDPI(X));
  Ck.SetTop(TControl.AdjustToDPI(Y));
end;

procedure THunterGUI.CreateEdit(var Ed: TLabeledEdit; Parent: TControl; Cap, DefaultText: String; X, Y: Int32);
begin
  Ed.Create(Parent);
  Ed.SetCaption(Cap);
  Ed.SetText(DefaultText);
  Ed.SetLeft(TControl.AdjustToDPI(X));
  Ed.SetTop(TControl.AdjustToDPI(Y));
  Ed.SetWidth(60);
end;

procedure THunterGUI.CreateLabel(var Lbl: TLabel; Parent: TControl; Cap: String; X, Y, W: Int32; Fnt: TFont = nil);
begin
  Lbl.Create(Parent);
  Lbl.SetCaption(Cap);
  Lbl.SetLeft(TControl.AdjustToDPI(X));
  Lbl.SetTop(TControl.AdjustToDPI(Y));
  Lbl.SetWidth(TControl.AdjustToDPI(W));
  if Fnt <> nil then Lbl.SetFont(Fnt);
end;

procedure THunterGUI.Run(); override;
const
  PATH = 'Configs/hunter.ini';
var
  Font, Bold: TFont;
  Tab: TTabSheet;
  SavedBreakAfter, SavedBreakFor: String;
  SavedBlockInput, SavedBankMoths, SavedOuterFortis, SavedBuryBones, SavedSleeps: Boolean;
  SavedMode, SavedWhistle, SavedPouch, SavedFood, SavedFoodAmount: Int32;
  SavedSunlightAntlers, SavedSunlightMeat, SavedMoonlightAntlers, SavedMoonlightMeat: Int32;
begin
  Self.Setup('Hunter', Point(800, 500), False);
  Self.Start.SetOnClick(@Self.StartScript);

  SavedBreakAfter := ReadINI('Hunter', 'BreakAfter', PATH);
  if SavedBreakAfter = '' then SavedBreakAfter := '45';

  SavedBreakFor := ReadINI('Hunter', 'BreakFor', PATH);
  if SavedBreakFor = '' then SavedBreakFor := '5';

  SavedBlockInput := StrToBoolDef(ReadINI('Hunter', 'BlockInput', PATH), False);
  SavedSleeps := StrToBoolDef(ReadINI('Hunter', 'Sleeps', PATH), False);
  SavedMode := StrToIntDef(ReadINI('Hunter', 'Mode', PATH), 0);
  SavedBankMoths := StrToBoolDef(ReadINI('Hunter', 'BankMoths', PATH), False);
  SavedOuterFortis := StrToBoolDef(ReadINI('Hunter', 'OuterFortis', PATH), False);
  SavedWhistle := StrToIntDef(ReadINI('Hunter', 'Whistle', PATH), 0);
  SavedPouch := StrToIntDef(ReadINI('Hunter', 'Pouch', PATH), 0);
  SavedBuryBones := StrToBoolDef(ReadINI('Hunter', 'BuryBones', PATH), False);
  SavedFood := StrToIntDef(ReadINI('Hunter', 'Food', PATH), 2);
  SavedFoodAmount := StrToIntDef(ReadINI('Hunter', 'FoodAmount', PATH), 3);
  SavedSunlightAntlers := StrToIntDef(ReadINI('Hunter', 'SunlightAntlers', PATH), 0);
  SavedSunlightMeat := StrToIntDef(ReadINI('Hunter', 'SunlightMeat', PATH), 0);
  SavedMoonlightAntlers := StrToIntDef(ReadINI('Hunter', 'MoonlightAntlers', PATH), 0);
  SavedMoonlightMeat := StrToIntDef(ReadINI('Hunter', 'MoonlightMeat', PATH), 0);

  Font.Init();
  Font.setName('Segoe UI');
  Font.SetQuality(fqCleartype);
  Self.Form.setFont(Font);
  Self.PageControl.SetFont(Font);

  Bold.Init();
  Bold.setName('Segoe UI Semibold');
  Bold.SetQuality(fqCleartype);

  Self.AddTab('Settings');
  Tab := Self.GetTab('Settings');
  Tab.SetTooltip('');

  Self.CreateEdit(Self.edit_BreakAfter, Tab, 'Break after', SavedBreakAfter, 30, 160);
  Self.CreateEdit(Self.edit_BreakFor, Tab, 'Break for', SavedBreakFor, 100, 160);

  Self.CreateCheck(Self.cb_BlockInput, Tab, 'Block real input', 30, 210);
  Self.cb_BlockInput.SetChecked(SavedBlockInput);

  Self.CreateCheck(Self.cb_Sleeps, Tab, 'Take sleeps', 30, 235);
  Self.cb_Sleeps.SetChecked(SavedSleeps);
  Self.cb_Sleeps.SetToolTip('Will go to sleep at approximately 12PM your local time for 7 hours.');

  Self.CreateCombo(Self.combo_Mode, Tab, 'Mode', 30, 260, 120, MODE_NAMES, SavedMode);
  Self.combo_Mode.Combobox.setOnChange(@Self.ModeComboboxOnChange);

  Self.CreateLabel(Self.lab_Title, Tab, 'Script page and instructions:', 30, 380, 200, Bold);
  Self.lab_Title.SetFontSize(12);

  Self.CreateLabel(Self.lab_Info, Tab, 'Elixer Scripts', 30, 400, 200);
  Self.lab_Info.SetFontColor($FF0000);
  Self.lab_Info.setOnClick(@Self.lab_Info.OpenLink);
  Self.lab_Info.setCursor(crHandPoint);

  Self.CreateCheck(Self.cb_BankMoths, Tab, 'Bank moonlight moths', 220, 180);
  Self.cb_BankMoths.SetChecked(SavedBankMoths);
  Self.cb_BankMoths.Checkbox.SetOnChange(@Self.OnHunterCheckboxChanged);

  Self.CreateCheck(Self.cb_OuterFortis, Tab, 'Outer Fortis Quetzal site built', 220, 180);
  Self.cb_OuterFortis.SetChecked(SavedOuterFortis);

  Self.CreateCombo(Self.combo_Whistle, Tab, 'Whistle', 220, 210, 160, ['None', 'Basic quetzal whistle', 'Enhanced quetzal whistle', 'Perfected quetzal whistle', 'Perfected quetzal whistle(i)'], SavedWhistle);
  Self.combo_Whistle.Combobox.SetOnChange(@Self.WhistleComboboxOnChange);

  Self.CreateCombo(Self.combo_Pouch, Tab, 'Meat pouch', 220, 260, 160, ['None', 'Small meat pouch (open)', 'Large meat pouch (open)'], SavedPouch);

  Self.CreateCheck(Self.cb_BuryBones, Tab, 'Bury big bones', 220, 310);
  Self.cb_BuryBones.SetChecked(SavedBuryBones);

  Self.CreateCombo(Self.combo_Food, Tab, 'Food', 420, 160, 120, ['Swordfish', 'Tuna', 'Lobster', 'Bass', 'Shark', 'Cooked karambwan'], SavedFood);
  Self.CreateCombo(Self.combo_FoodAmount, Tab, 'Amount', 550, 160, 50, ['1', '2', '3', '5', '8', '10'], SavedFoodAmount);
  Self.combo_FoodAmount.SetToolTip('How many food to withdraw from bank?');

  Self.CreateLabel(Self.lab_Sunlight, Tab, 'Sunlight antelopes', 420, 210, 200, Bold);
  Self.CreateCombo(Self.combo_SunlightAntlers, Tab, 'Antlers', 420, 230, 80, ['Fletch', 'Bank', 'Drop'], SavedSunlightAntlers);
  Self.CreateCombo(Self.combo_SunlightMeat, Tab, 'Meat', 510, 230, 80, ['Bank', 'Drop'], SavedSunlightMeat);

  Self.CreateLabel(Self.lab_Moonlight, Tab, 'Moonlight antelopes', 420, 280, 200, Bold);
  Self.CreateCombo(Self.combo_MoonlightAntlers, Tab, 'Antlers', 420, 300, 80, ['Fletch', 'Bank', 'Drop'], SavedMoonlightAntlers);
  Self.CreateCombo(Self.combo_MoonlightMeat, Tab, 'Meat', 510, 300, 80, ['Bank', 'Drop'], SavedMoonlightMeat);

  Font.Free();
  Bold.Free();

  Self.CreateChoreSettings();
  Self.UpdateVisibility();
  Self.OnTabChanged(@Self.OnTabChanged);
  Self.CreateAccountManager(Tab);
  inherited;
end;

procedure WriteDebug(Message: String);
begin
  WriteLn(SRL.TimeStamp(), ':[Script]: ', Message);
end;

procedure ResetRumour();
begin
  Rumour := UNSET;
end;

function GetWhistleCharges(): Int32;
var
  Msg: String;
  i: Int32;
begin
  if ToStr(Whistle).Contains('(i)') then
  begin
    Wait(4000, 5000);
    Exit(5);
  end;

  Msg := Chat.GetMessage(7);
  if Msg.Contains('quetzal whistle has') then
  begin
    Result := Msg.ExtractInteger();
    WriteDebug('Current whistle charges: ' + ToStr(Result));
    Exit(Result);
  end;

  if WaitUntil(Inventory.Open(), 200, 1000) and Inventory.ClickItem(Whistle, 'Check') then
    WaitEx(1375, 150);

  for i := 7 downto 0 do
  begin
    Msg := Chat.GetMessage(i);
    if Msg.Contains('quetzal whistle has') then
    begin
      Result := Msg.ExtractInteger();
      WriteDebug('Current whistle charges: ' + ToStr(Result));
      Exit(Result);
    end;
  end;
end;

function SetupTool(Item: TRSItem; Amount: Int32 = 1; IsStackable: Boolean = False): TTool;
begin
  Result.Item := Item;
  Result.Amount := Amount;
  Result.IsStackable := IsStackable;
end;

function HasAllTools(): Boolean;
var
  T: TTool;
begin
  for T in Tools do
    if T.GetCount() < T.Amount then
      Exit(False);

  Result := True;
end;

function GetToolItems(): TRSItemArray;
var
  T: TTool;
begin
  for T in Tools do
    Result += T.Item;
end;

procedure HopWorlds();
begin
  if Chat.HasContinue() then
    Chat.ClickContinue(50);

  WaitEx(500, 100);

  WorldHopper.Hop(Login.GetPlayer().Worlds);
end;

function IsInGuild(): Boolean;
begin
  Result := SRL.PointInPoly(RSW.GetMyPos(), [[443, 327], [688, 332], [697, 526], [452, 539]]);
end;

function IsOnRoof(): Boolean;
begin
  Result := SRL.PointInPoly(RSW.GetMyPos(), [[2123, 1403], [2183, 1403], [2183, 1463], [2123, 1463]]);
end;

function IsInBasement(): Boolean;
begin
  Result := SRL.PointInPoly(RSW.GetMyPos(), [[387, 1171], [580, 1177], [594, 1450], [400, 1447]]);
end;

function IsInZone(): Boolean;
begin
  Result := SRL.PointInPoly(RSW.GetMyPos(), Zone);
end;

procedure ResetTimer(Task: PBreakTask);
var
  T: PBreakTask;
begin
  InactivityTimer.Reset();
  T := Task;
end;

procedure ResetSleep(Task: PSleepTask);
var
  T: PSleepTask;
begin
  InactivityTimer.Reset();
  T := Task;
end;

function InCombat(Duration: UInt32 = 850): Boolean;
var
  Bars: TRSHPBarArray;
  T: TCountdown;
  Bar: TRSHPBar;
  Top: TBox;
begin
  Top := Mainscreen.GetPlayerBox();
  Top.Y1 -= 16;

  T.Init(Duration);

  while not T.IsFinished() do
  begin
    Bars := Mainscreen.FindHPBars();

    for Bar in Bars do
      if Top.Contains(Bar.Bounds.Center()) then
        Exit(True);

    Sleep(50);
  end;
end;

function FindTrapMS(out TrapRect: TRectangle; Height: Double = 0): Boolean;
begin
  TrapRect := RSW.GetTrapMS(Trap, Height);
  Result := Mainscreen.Bounds.Contains(TrapRect.Mean());
end;

function DoQuetzalTravel(Destination: EQuetzalSite; ViaWhistle: Boolean): Boolean;
begin
  if not ViaWhistle then
  begin
    if Destination = qsOUTER_FORTIS then
      if not (GuildQuetzal.Click() or GuildQuetzal.WalkClick()) then Exit(False)
    else
      if not (OuterQuetzal.Click() or OuterQuetzal.WalkClick()) then Exit(False);
  end else if not (WaitUntil(Inventory.Open(), 200, 1000) and Inventory.ClickItem(Whistle, ['Signal', 'Teleport'])) then
      Exit(False);

  if not WaitUntil(QuetzalInterface.IsOpen(), 250, 1500) then
  begin
    WriteDebug('Quetzal interface never opened');

    if ViaWhistle then
    begin
      WriteDebug('Make sure that in your OSRS game settings you have the following:');
      WriteDebug('"Quetzal whistle - Default to hunter guild" unchecked.');
    end;

    Exit(False);
  end;

  Wait(500, 1000);

  if not QuetzalInterface.Travel(Destination) then
  begin
    WriteDebug('Quetzal travel failed!');
    if not ViaWhistle then
      OuterFortis := False;
    Exit(False);
  end;

  if Destination = qsOUTER_FORTIS then
    Result := WaitUntil(RSW.GetMyPos().DistanceTo(OuterQuetzal.Coordinates[0]) < 64, 500, 7500)
  else
    Result := WaitUntil(RSW.GetMyPos().DistanceTo(GuildQuetzal.Coordinates[0]) < 64, 500, 7500);

  Wait(500, 1000);

  if ViaWhistle then
    Charges := GetWhistleCharges();
end;

function CheckPitfallColor(Bounds: TBox; Pit: TPointArray; Color: TCTS2Color): TPointArray;
var
  TPA: TPointArray;
  Pt: TPoint;
begin
  SRL.FindColors(TPA, Color, Bounds);

  if Length(TPA) > 0 then
    for Pt in TPA do
      if SRL.PointInPoly(Pt, Pit) then
        Result.Append(Pt);
end;

function ForcePitfallState(): ETrapState;
var
  Option: TRSChooseOption_Option;
  Rect: TRectangle;
  Search: String;
begin
  if not FindTrapMS(Rect) then
    Exit(UNKNOWN);

  WriteDebug('Force searching pitfall');

  Mouse.HumanMove(Rect.Mean());
  WaitEx(200, 50);
  Search := Mainscreen.GetUpText();
  WriteDebug('Uptext: ' + Search);

  if Search.Contains('Trap Pit') then
    Result := EMPTY
  else if Search.Contains('Jump') then
    Result := BUILT
  else if Search.Contains('Collapsed') then
    Result := CAUGHT
  else
  begin
    Search := '';
    Mouse.Click(MOUSE_RIGHT);

    if not ChooseOption.IsOpen(500) then
      Exit(UNKNOWN);

    WaitEx(250, 100);

    for Option in ChooseOption.GetOptions() do
      Search += Option.Text;

    WriteDebug('Menus: ' + Search);

    if Search.Contains('Trap Pit') then
      Result := EMPTY
    else if Search.Contains('Jump') then
      Result := BUILT
    else if Search.Contains('Collapsed') then
      Result := CAUGHT;

    WaitEx(250, 100);
    WaitUntil(ChooseOption.Close(), 50, 500);
  end;
end;

function SpotHasItemDot(Spot: TPoint): Boolean;
var
  Dots: TPointArray;
  Dist: Double;
  Dot: TPoint;
begin
  Dots := Minimap.GetDots(ERSMinimapDot.ITEM);

  if Length(Dots) = 0 then
    Exit(False);

  for Dot in Dots do
  begin
    Dist := RSW.WorldToMM(Spot).DistanceTo(Dot);
    if Dist < 5 then
    begin
      WriteDebug('Item on Trap tile, dist: ' + ToStr(Round(Dist, 2)));
      Exit(True);
    end;
  end;
end;

function GetPitfallState(): ETrapState;
var
  CaughtTPA, BuiltTPA: TPointArray;
  Rect: TRectangle;
  Pit: TPointArray;
  Bds: TBox;
begin
  if not FindTrapMS(Rect) then
    Exit(UNKNOWN);

  Bds := Rect.Bounds();
  Bds.LimitTo(Mainscreen.Bounds);

  SRL.FindColors(Pit, PitColor, Bds);

  if Length(Pit) = 0 then
    Exit(UNKNOWN);

  Pit := Pit.ConvexHull();
  CaughtTPA := CheckPitfallColor(Bds, Pit, CaughtColor);
  BuiltTPA := CheckPitfallColor(Bds, Pit, BuiltColor);

  if Length(Pit) > (Length(CaughtTPA) + Length(BuiltTPA)) then
    Result := EMPTY
  else if Length(CaughtTPA) > (Length(BuiltTPA) * 5) then
    Result := CAUGHT
  else if Length(BuiltTPA) > (Length(CaughtTPA) * 5) then
    Result := BUILT
  else
    Result := ForcePitfallState();
end;

function HasGainedXP(): Boolean;
var
  t: Int32 := XPBar.Read() - StartXP;
begin
  if t > 0 then
  begin
    Result := t > GainedXP;

    if Result then
      GainedXP := t;
  end;
end;

procedure PrintProgress();
var
  Total, Hourly: String;
  Hours: Double;
begin
  Hours := GetTimeRunning() / 3600000;
  Total := ToStr(Round((GainedXP/1000), 0), ' k ');
  Hourly := ToStr('(', Round((GainedXP/(Hours*1000)), 1), ' k / hr)');
  WriteLn(SRL.TimeStamp(), ':[Experience]: ', Total, Hourly);

  if Mode = Rumours then
  begin
    Total := ToStr(Completed, ' ');
    Hourly := ToStr('(', Round((Completed/Hours), 1), ' / hr)');
    WriteLn(SRL.TimeStamp(), ':[Rumours]: ', Total, Hourly);
  end;

  ReportTimer.Reset();
end;

function ShouldStop(): Boolean;
begin
  if HasGainedXP() then
    InactivityTimer.Reset();

  if ReportTimer.ElapsedTime() > 120000 then
    PrintProgress();

  Result := InactivityTimer.ElapsedTime() > 300000;
end;

function ShouldHop(): Boolean;
var
  Dots: TPointArray;
  Dot: TPoint;
begin
  if Prey in [NONE, UNSET, SUNLIGHT_MOTH, RUBY_HARVEST] then
    Exit(False);

  Dots := Minimap.GetDots(ERSMinimapDot.PLAYER);

  if Length(Dots) = 0 then
    Exit(False);

  for Dot in Dots do
    if SRL.PointInPoly(RSW.MMToWorld(Dot), Zone) then
    begin
      if (Minimap.GetHPPercent() < 65) or InCombat(1000) then
        Exit(False);

      Exit(True);
    end;
end;

function OpenBank(): Boolean;
begin
  if WaitUntil(Bank.IsOpen(), 250, 1500) then
    Exit(True);

  if not (Chest.Click() or Chest.WalkClick()) then
  begin
    RSW.WalkBlind(Chest.Coordinates[0] + [8, -4]);
    Chest.Click();
  end;

  Result := WaitUntil(Bank.IsOpen(), 1500, 12000);
end;

procedure LoadProfile(TargetPrey: EAnimal);
begin
  Prey := TargetPrey;
  Zone := Profiles[TargetPrey].ZoneBox;
  Trap := Profiles[TargetPrey].TrapCenter;
  Walk := Profiles[TargetPrey].WalkCenter;
  PitColor := Profiles[TargetPrey].PitColor;
  BuiltColor := Profiles[TargetPrey].BuiltColor;
  CaughtColor := Profiles[TargetPrey].CaughtColor;
  ButterflyColor := Profiles[TargetPrey].ButterflyColor;
end;

procedure Init();
begin
  WriteDebug(ToStr('Starting in mode: ', Mode));

  if Length(Login.GetPlayer().Worlds) < 5 then
  begin
    WriteDebug('WARNING! Your profile has less than 5 worlds set up.');
    WriteDebug('Adding 5 temporary UK worlds for this run.');
    Login.Players[Login.PlayerIndex].Worlds += [503, 504, 505, 506, 507, 508];
  end;

  if not RSClient.IsLoggedIn() then
    Login.LoginPlayer();

  if WaitUntil(RSClient.IsLoggedIn(), 250, 12000)  then
    StartXP := XPBar.Read();

  if StartXP < 1024 then
    TerminateScript('Failed to read XP, make sure XPBar is set up!');

  Antiban.AddTask(ONE_MINUTE * 6, @Antiban.RandomRotate, 1);
  Antiban.AddTask(ONE_MINUTE * 8, @Antiban.RandomRightClick, 1);
  Antiban.AddTask(ONE_MINUTE * 8, @Antiban.DoLoseFocus, 1);
  Antiban.AddTask(ONE_MINUTE * 8, @Antiban.RandomKeyboard, 1);
  Antiban.OnFinishBreak := @ResetTimer;
  Antiban.OnFinishSleep := @ResetSleep;

  Mouse.Speed := SRL.NormalRange(26, 32);
  Mouse.Wind := SRL.NormalRange(1, 3);
  Mouse.Gravity := SRL.NormalRange(18, 22);
  Mouse.MissChance := SRL.NormalRange(4, 8);

  if Mode = EMode.RUMOURS then
    Antiban.AddTask(ONE_MINUTE * 15, @ResetRumour, 0.25);

  if Options.GetNPCAttackOption() <> ERSAttackOption.HIDDEN then
    Options.SetNPCAttackOption(ERSAttackOption.HIDDEN);

  if not InRange(Options.GetZoomLevel(), 16, 20) then
    Options.SetZoomLevel(Random(16, 20));

  MM2MS.SetupZoom();
  PlayerBox := Mainscreen.GetPlayerBox();
  WaitUntil(Equipment.Open(), 50, 500);

  HasFletchingKnife := Equipment.ContainsItem('Fletching knife');

  if (Mode in [RUMOURS, SUNLIGHT_ANTELOPES]) and not Equipment.ContainsAny(Axes) then
    TerminateScript('This mode requires you to equip an axe that you can cut logs with.');

  WaitUntil(Inventory.Open(), 50, 500);

  if Mode = RUMOURS then
  begin
    if Whistle = Default(TRSItem) then
      TerminateScript('You need to select a whistle when in rumour mode');
    Rumour := EAnimal.UNSET;
  end;

  if (BirdhouseRunner.Enabled or FarmRunner.Enabled) and (Whistle = Default(TRSItem)) then
    TerminateScript('how did you enable chores with no whistle?');

  if BirdhouseRunner.Enabled then
    BirdhouseRunner.Init([Whistle], [1]);

  if FarmRunner.Enabled then
    FarmRunner.Init([Whistle], [1]);

  ScriptWalker := @RSW;

  if UseWhistle then
  begin
    if (Whistle = 'Perfected quetzal whistle(i)') then
      Charges := 5
    else
      Charges := -1;
  end;

  Junk += ['Moonlight antelope fur', 'Sunlight antelope fur', 'Bones', 'Raw bird meat'];

  if not Burying then
    Junk += 'Big bones';

  Tools := [];

  if UseWhistle then
    Tools += SetupTool(Whistle);

  if Mode in [EMode.RUMOURS, EMode.SUNLIGHT_ANTELOPES, EMode.MOONLIGHT_ANTELOPES] then
  begin
    Tools += SetupTool('Teasing stick');

    if not HasFletchingKnife then
      Tools += SetupTool('Knife');

    if CutAntlers then
      Tools += SetupTool('Chisel');

    if UsePouch then
      Tools += SetupTool(Pouch);

    Tools += SetupTool(Food, FoodAmount);
  end;

  if BankMoths then
  begin
    Tools := [];
    Tools += SetupTool('Coins', 40, True);
  end;

  if Mode = EMode.CRIMSON_SWIFTS then
    Tools += SetupTool('Bird snare', 5, True);

  case Mode of
    EMode.MOONLIGHT_MOTHS: LoadProfile(MOONLIGHT_MOTH);
    EMode.SUNLIGHT_ANTELOPES: LoadProfile(SUNLIGHT_ANTELOPE);
    EMode.MOONLIGHT_ANTELOPES: LoadProfile(MOONLIGHT_ANTELOPE);
    EMode.RUBY_HARVESTS: LoadProfile(RUBY_HARVEST);
    EMode.SUNLIGHT_MOTHS: LoadProfile(SUNLIGHT_MOTH);
    EMode.CRIMSON_SWIFTS: LoadProfile(CRIMSON_SWIFT);
  end;

  WriteDebug('Mode: ' + MODE_NAMES[Mode]);
  WriteDebug('Tools: ' + ToStr(Tools));

  if not (Mode in [EMode.MOONLIGHT_MOTHS, EMode.SUNLIGHT_MOTHS, EMode.RUBY_HARVESTS]) then
    WriteDebug('Junk: ' + ToStr(Junk));

  if UseWhistle then WriteDebug('Whistle: ' + ToStr(Whistle));
  if UsePouch then WriteDebug('Pouch: ' + ToStr(Pouch));

  if Mode in [EMode.RUMOURS, EMode.SUNLIGHT_ANTELOPES, EMode.MOONLIGHT_ANTELOPES] then
  begin
    if Food <> '' then WriteDebug('Food: ' + ToStr(FoodAmount) + 'x ' + ToStr(Food));
    WriteDebug('Cut Antlers: ' + ToStr(CutAntlers));
    WriteDebug('Bury Bones: ' + ToStr(Burying));
    WriteDebug('Equipped Fletch Knife: ' + ToStr(HasFletchingKnife));
  end;

  if Mode = EMode.MOONLIGHT_MOTHS then
    WriteDebug('Bank Moths: ' + ToStr(BankMoths));

  if BirdhouseRunner.Enabled or FarmRunner.Enabled then
    WriteDebug('Chores: Birdhouses=' + ToStr(BirdhouseRunner.Enabled) + ', Farming=' + ToStr(FarmRunner.Enabled));

  QuetzalInterface.Init();

  InactivityTimer.Start();
  ReportTimer.Start();
end;

procedure ClimbRoof();
begin
  if Rope.Click() then
    WaitUntil(IsOnRoof(), 1500, 6000)
  else
    RSW.WebWalk([534, 432]);
end;

procedure ProcessMixes();
var
  Slots: TIntegerArray;
begin
  if not Inventory.FindItems(Meats, Slots) then
    Exit();

  if not Inventory.ContainsAll(['Pestle and mortar', 'Moonlight moth']) then
    Exit();

  if not Inventory.Use(Slots[0], 'Moonlight moth') then
    Exit();

  if WaitUntil(not Inventory.ContainsItem('Moonlight moth'), 500, 25000) then
    InactivityTimer.Reset();
end;

procedure RestockMixes();
var
  b: TRSBankItem;
  Item: TRSItem;
begin
  if not OpenBank() then
    Exit();

  Wait(500, 1000);

  if Bank.DepositRandomItems(['Pestle and mortar']) then
    Wait(500, 1500);

  if not Inventory.ContainsItem('Pestle and mortar') then
  begin
    b := TRSBankItem.Setup('Pestle and mortar', 1, False);
    if Bank.WithdrawItem(b, False) then
      WaitEx(500, 50);
  end;

  if not WaitUntil(Bank.ContainsItem('Moonlight moth'), 250, 1250) then
  begin
    WriteDebug('No moths in bank');
    WriteDebug('Make sure moths are visible in main bnak tab');
    TerminateScript();
  end;

  b := TRSBankItem.Setup('Moonlight moth', 13, False);
  if Bank.WithdrawItem(b, False) then
    WaitEx(500, 50);

  if not WaitUntil(Bank.ContainsAny(Meats), 250, 1250) then
  begin
    WriteDebug('No meat in bank');
    WriteDebug('Make sure a raw hunter meat is visible in the main bank tab');
    TerminateScript();
  end;

  for Item in Meats do
    if Bank.ContainsItem(Item) then
      begin
        b := TRSBankItem.Setup(Item, Bank.QUANTITY_ALL, False);
        Break();
      end;

  if Bank.WithdrawItem(b, False) then
    WaitEx(500, 50);

  if Bank.IsOpen() then
    Bank.Close(50);
end;

procedure GetMeats();
var
  b: TRSBankItem;
  Item: TRSItem;
begin
  if not OpenBank() then
    Exit();

  if Inventory.CountEmptySlots() < 5 then
    Bank.DepositRandomItems(Rares.Combine([Whistle]));

  if not WaitUntil(Bank.ContainsAny(Meats), 250, 1250) then
  begin
    WriteDebug('No meat in bank to recharge whistle');
    WriteDebug('Make sure a raw hunter meat is visible in the main bank tab');
    TerminateScript();
  end;

  if not Inventory.ContainsItem(Whistle) then
  begin
    b := TRSBankItem.Setup(Whistle, 1, False);
    if Bank.WithdrawItem(b, False) then
      WaitEx(500, 50);
  end;

  for Item in Meats do
    if Bank.ContainsItem(Item) then
      begin
        b := TRSBankItem.Setup(Item, Bank.QUANTITY_ALL, False);
        Break();
      end;

  if Bank.WithdrawItem(b, False) then
    WaitEx(500, 50);

  if Bank.IsOpen() then
    Bank.Close(50);
end;

procedure RechargeWhistle();
var
  M: Int32 := Inventory.CountItems(Meats);
begin
  WriteDebug('Raw meats in inventory: ' + ToStr(M));

  if not Pitri.SelectOption(['Recharge-whistle']) then
  begin
    WriteDebug('Failed to click Pitri');
    Antiban.RandomRotate();
    Exit();
  end;

  if WaitUntil(M > Inventory.CountItems(Meats), 500, 5000) then
  begin
    WriteDebug('Successfully gave our meat (raw) to Pitri.');
    Charges := GetWhistleCharges();
  end;
end;

procedure BuryBones();
begin
  if Inventory.ClickItem('Big bones') then
    WaitEx(500, 100);
end;

function InteractWithPitfall(UpTexts: TStringArray): Boolean;
var
  Rect: TRectangle;
begin
  if Inventory.GetSelectedSlot() <> -1 then
    Inventory.SetSelectedSlot(-1);

  if not FindTrapMS(Rect) then
    Exit(False);

  Result := Mainscreen.ClickHelper(Rect.Mean(), UpTexts) and Mainscreen.DidRedClick();

  if not Result then
  begin
    WriteDebug('Failed to interact with pitfall.');

    if SRL.Dice(25) then
    begin
      WriteDebug('Trying to rotate to solve the issue.');
      Antiban.RandomRotate();
    end;
  end;
end;

function WithdrawTools(): Boolean;
var
  ToolItem: TRSBankItem;
  T: TTool;
begin
  if not Bank.IsOpen() then
    Exit(False);

  for T in Tools do
  begin
    Wait(300, 600);

    if T.GetCount() >= T.Amount then
      Continue;

    if not Bank.ContainsItem(T.Item) then
    begin
      WriteDebug(ToStr('Failed to find: ', T.Item));
      WriteDebug('Make sure that it is visible in your bank.');
      Continue;
    end;

    ToolItem := TRSBankItem.Setup(T.Item, T.Amount, False);

    if not Bank.WithdrawItem(ToolItem, False) then
      Exit(False);

    WaitUntil(T.GetCount() >= T.Amount, 500, 1500);
  end;

  Result := HasAllTools();
end;

procedure Restock();
begin
  if not OpenBank() then
    Exit();

  if (Food <> '') and Inventory.ContainsAny([Food]) then
    if Minimap.GetHPPercent() < 90 then
      if Inventory.ClickItem(Food, 'Eat') then
        WaitEx(800, 100);

  if Bank.DepositAll() then
    Wait(300, 600);

  if not WaitUntil(Inventory.CountEmptySlots() > 15, 250, 1500) then
    Exit();

  for 0 to 5 do
    if WithdrawTools() then
      Break();

  Wait(300, 600);

  if UsePouch and Inventory.ContainsItem(Pouch) then
  begin
    Inventory.ClickItem(Pouch, 'Empty');
    Wait(500, 750);
  end;

  if Bank.IsOpen() then
    Bank.Close(50);

  Antiban.DoAntiban(True, True);
end;

procedure EatFood();
begin
  if WaitUntil(Inventory.Open(), 200, 1000) and Inventory.ClickItem(Food, 'Eat') then
    WaitEx(750, 50)
  else
    Antiban.RandomRotate();
end;

function FindTrees(): TPointArray;
begin
  if SRL.FindColors(Result, CTS2(5678734, 6, 0.08, 0.04), Mainscreen.Bounds) > 0 then
    Result := Result.Cluster(25).Means().Sorted(Mainscreen.Center);
end;

procedure ChopTree();
var
  Exp: Int64 := XPBar.Read();
  Pt: TPoint;
begin
  for Pt in FindTrees() do
  begin
    if not Mainscreen.ClickHelper(Pt, ['Chop']) then
      Continue();

    if WaitUntil(Exp < XPBar.Read(), 500, 5500) then
      Exit();
  end;
end;

procedure Recovery();
begin
  RSW.WalkBlind(Walk);
  Antiban.RandomRotate();
end;

procedure ChopLogs();
begin
  if Length(FindTrees()) = 0 then
    RSW.WalkBlind([1262, 628]);

  Minimap.DoneMoving();

  for 0 to Max(0, Min(6, Inventory.CountEmptySlots() - 6)) do
  begin
    ChopTree();

    if Inventory.CountEmptySlots() < 7 then
      Break();
  end;
end;

procedure GetLogs();
var
  PrevCount: Int32;
begin
  for 0 to Random(1, 2) do
  begin
    PrevCount := Inventory.CountItem('Logs');

    if Roots.Click() then
      WaitUntil(PrevCount < Inventory.CountItem('Logs'), 500, 2500)
    else
      Antiban.RandomRotate();

    WaitEx(250, 200);
  end;
end;

function TeaseAntelope(): Boolean;
var
  ATPA: T2DPointArray;
  TPA: TPointArray;
  Pt: TPoint;
begin
  ATPA := Mainscreen.FindObject(Finder);

  if ATPA.Len() = 0 then
  begin
    WriteDebug('No antelopes found on MS.');

    if InactivityTimer.ElapsedTime() > (3 * ONE_MINUTE) then
    begin
      WriteDebug('Antelopes hiding, hopping worlds.');
      HopWorlds();
    end else
    begin
      if SRL.Dice(50) then
        Antiban.RandomRotate()
      else
        RSW.WalkBlind(Walk);
    end;

    Exit(False);
  end;

  TPA := ATPA.Means().Sorted(RSW.GetTileMS(Walk).Mean());

  for Pt in TPA do
    if PlayerBox.Contains(Pt) then
      TPA.Remove(Pt);

  if TPA.Len() = 0 then
    Exit(False);

  Mouse.HumanMove(TPA[0]);

  if Mainscreen.IsUpText('Tease') then
    Mouse.Click(MOUSE_LEFT);

  Result := Mainscreen.DidRedClick(350) or InCombat();

  if not Result and SRL.Dice(30) then
    Antiban.RandomRotate();
end;

procedure CatchPitfall();
  procedure _StepLureTile(Tile: TPoint);
  var
    Rect: TRectangle;
  begin
    if SRL.Dice(50) then
    begin
      Rect := RSW.GetTileMS(Tile);
      if Mainscreen.Bounds.Contains(Rect) then
        Mainscreen.ClickHelper(Rect.Mean(), ['Walk here'])
      else
        RSW.WalkBlind(Tile);
    end else
      Mouse.Click(RSW.WorldToMM(Tile), MOUSE_LEFT);

    WaitUntil(RSW.AtTile(Tile, 2), 100, 3500);
  end;
var
  Exp: Int64 := XPBar.Read();
begin
  if not InCombat(600) then
  begin
    if not TeaseAntelope() then
      Exit();

    if WaitUntil(Minimap.HasFlag(), 50, 500) then
      Minimap.WaitFlag();

    Minimap.DoneMoving();
    WaitEx(250, 50);
  end;

  case Prey of
    SUNLIGHT_ANTELOPE:
      if not InRange(RSW.GetMyPos().Y, 608, 612) then
      begin
        if not InRange(RSW.GetMyPos().X, 1262, 1302) then
          if not RSW.AtTile([1282, 588], 13) then
            _StepLureTile([1282, 588]);

        if not RSW.AtTile([1282, 608], 13) then
          _StepLureTile([1278, 608]);
      end;

    MOONLIGHT_ANTELOPE:
      if not InRange(RSW.GetMyPos().Y, 1404, 1408) then
        if not RSW.AtTile([494, 1408], 13) then
          _StepLureTile([494, 1408]);
  end;

  Minimap.DoneMoving();

  if InteractWithPitfall(['Jump']) then
  begin
    if WaitUntil(InRange(RSW.GetMyPos().X, Trap.X - 1, Trap.X + 1), 200, 7500) then
    begin
      WaitEx(1000, 200);
      Minimap.DoneMoving();
    end;

    Mouse.HumanMove(RSW.GetTrapMS(Trap).Mean());
    WaitUntil(Mainscreen.IsUpText('Collapsed'), 500, 6500);
    WaitEx(175, 50);
  end;

  if Mainscreen.GetUpText().Contains('Jump') then
    Exit();

  if InteractWithPitfall(['Collapsed']) then
    WaitUntil(Exp < XPBar.Read(), 650, 6000);
end;

procedure FletchBolts();
var
  Antler: TRSItem;
begin
  for Antler in Antlers do
    if Inventory.ContainsItem(Antler) then
    begin
      Inventory.Use(Antler, 'Chisel');

      if Inventory.CountItems([Antler]) > 1 then
      begin
        if not WaitUntil(Make.IsOpen(), 500, 1500) then
          Exit();

        Make.Select(0, Make.QUANTITY_ALL, SRL.Dice(50));
      end;

      WaitUntil(not Inventory.ContainsItem(Antler) or InCombat(), 500, 12500);
    end;
end;

procedure WalkZone();
begin
  if not IsInBasement() or not RSW.WebWalk(Walk) then
    RSW.WalkBlind(Walk);
end;

procedure EnterBasement();
begin
  if WaitUntil(IsInBasement(), 100, 600) then
    Exit();

  if Upstairs.WalkClick() and WaitUntil(IsInBasement(), 500, 12500) then
    WaitEx(500, 100)
  else
    RSW.WebWalk([534, 432]);
end;

procedure ExitBasement();
begin
  if Downstairs.WalkClick() and WaitUntil(IsInGuild(), 500, 12500) then
    WaitEx(500, 100)
  else
    RSW.WebWalk([482, 1276]);
end;

procedure BuyJars();
begin
  if not Imia.IsVisible() then
    RSW.WebWalk([554, 388]);

  if Imia.SelectOption(['Trade']) then
  begin
    if not WaitUntil(Store.IsOpen(), 1000, 10000) then
      Exit();

    if Inventory.IsFull() then
      Exit();

    if Store.ClickItem('Butterfly jar', 'Buy 50') then
      if WaitUntil(Inventory.ContainsItem('Butterfly jar'), 500, 1500) then
        WaitEx(500, 100);
  end else
    Antiban.RandomRotate();
end;

procedure TileStepMM(Tile: TPoint);
begin
  Mouse.Move(RSW.WorldToMM(Tile));
  WaitEx(200, 40);
  Mouse.Click(MOUSE_LEFT);
  WaitUntil(RSW.GetMyPos() = Tile, 250, 5350);
end;

procedure TileStepMS(Tile: TPoint);
var
  Rect: TRectangle := RSW.GetTileMs(Tile);
begin
  if Mainscreen.Bounds.Contains(Rect) and Mainscreen.ClickHelper(Rect.Mean(), ['Walk here']) then
    WaitUntil(RSW.GetMyPos() = Tile, 200, 5350);
end;

function MoveToTile(Tile: TPoint): Boolean;
begin
  if WaitUntil(RSW.GetMyPos() = Tile, 200, 1000) then
    Exit(True);

  case Random(0, 10) of
    0:     RSW.WalkBlind(Tile);
    1..5:  TileStepMS(Tile);
    6..10: TileStepMM(Tile);
  end;

  Result := WaitUntil(RSW.GetMyPos() = Tile, 200, 1000);
end;

procedure ChatWithWolf();
var
  Exp := XPBar.Read();
  Msg: String;
begin
  if not Wolf.IsVisible() and RSW.WebWalk(Point(482, 1248).Random(-4, 4, True)) then
    Minimap.DoneMoving();

  if Wolf.SelectOption(['Rumour']) then
  begin
    Rumour := UNSET;

    WaitUntil(Chat.HasContinue() or Chat.GetChat().Contains('about'), 500, 5500);

    if Chat.HasContinue() then
      if Chat.ClickContinue(50) then
        WaitEx(750, 150);

    if Chat.ClickOption('Yes.', SRL.Dice(40)) then
      WaitEx(750, 150);

    if WaitUntil(Exp < XPBar.Read(), 750, 2500) then
      Inc(Completed);

    Msg := Chat.GetChat().ToLower();

    if Msg.Contains('moonlight moth') then
      Rumour := MOONLIGHT_MOTH
    else if Msg.Contains('moonlight antelope') then
      Rumour := MOONLIGHT_ANTELOPE
    else if Msg.Contains('sunlight antelope') then
      Rumour := SUNLIGHT_ANTELOPE;

    WriteDebug(ToStr(Rumour));

    if Rumour <> UNSET then
      LoadProfile(Rumour);
  end else
    Antiban.RandomRotate();
end;

procedure ExitRoof();
begin
  if Trapdoor.Click() then
    WaitUntil(not IsOnRoof(), 2000, 6000)
  else
    Antiban.RandomRotate();
end;

procedure CatchFlying();
var
  Exp: Int64 := XPBar.Read();
  TPA: TPointArray;
  fpt: TPoint;
  i: Int32;
begin
  SRL.FindColors(TPA, ButterflyColor, Mainscreen.Bounds);

  if Length(TPA) = 0 then
    Exit();

  TPA := TPA.Cluster(10).Means();

  if (Mode = EMode.MOONLIGHT_MOTHS) or (Prey = EAnimal.MOONLIGHT_MOTH) then
    fpt := RSW.GetTileMS(Walk).Mean();

  for i := High(TPA) downto 0 do
  begin
    if PlayerBox.Contains(TPA[i]) then
    begin
      Delete(TPA, i);
      Continue();
    end;

    if (Mode = EMode.MOONLIGHT_MOTHS) or (Prey = EAnimal.MOONLIGHT_MOTH) then
    begin
      if TPA[i].DistanceTo(fpt) > 200 then
      begin
        RSClient.Image.DrawCrosshairs(TPA[i], 8, clRed);
        Delete(TPA, i);
      end else
        RSClient.Image.DrawCrosshairs(TPA[i], 8, clGreen);
    end;
  end;

  if Length(TPA) = 0 then
    Exit();

  if (Mode = EMode.MOONLIGHT_MOTHS) or (Prey = EAnimal.MOONLIGHT_MOTH) then
    fpt := Point(Floor((fpt.X + Mouse.Position().X)/2), Floor((fpt.Y + Mouse.Position().Y)/2))
  else
    fpt := Mouse.Position();

  TPA.Sort(fpt);
  RSClient.Image.DrawCrosshairs(TPA[0], 4, clPurple);

  Mouse.MissChance := 0;
  Mouse.CanIdle := False;
  Mouse.Move(TPA[0]);
  Mouse.CanIdle := True;
  Mouse.MissChance := SRL.NormalRange(2, 5);

  if not Mainscreen.IsUpText(['Catch', 'moth', 'Moth', 'Ruby']) then
    Exit();

  if SRL.Dice(3) then
  begin
    if ChooseOption.Open() then
      WaitEx(600, 100);
    if not ChooseOption.Select('Catch') then
      Exit();
  end else
    Mouse.Click(MOUSE_LEFT);

  if WaitUntil(Mainscreen.DidRedClick(), 50, 450) then
    WaitUntil((Exp < XPBar.Read()) or Chat.HasContinue(), 500, SRL.NormalRange(5000, 8000));

  if SRL.Dice(2) then
    WaitEx(3000, 500);

  if not ((Mode = EMode.MOONLIGHT_MOTHS) or (Prey = EAnimal.MOONLIGHT_MOTH)) then
    Antiban.DoAntiban(True, True);
end;

function CheckPitfall(): Boolean;
var
  Experience: Int64 := XPBar.Read();
begin
  if InteractWithPitfall(['Collapsed']) then
    Result := WaitUntil(Experience < XPBar.Read(), 650, 6000);
end;

procedure BuildPitfall();
var
  Logs: Int32 := Inventory.CountItem('Logs');
begin
  if not InteractWithPitfall(['Trap']) then
    Exit();

  if WaitUntil(Inventory.CountItem('Logs') < Logs, 250, 4000) then
  begin
    Wait(400, 700);
    CatchPitfall();
  end;
end;

procedure CheckRumour();
var
  Msg: String;
  i: Int32;
begin
  if not (WaitUntil(Inventory.Open(), 200, 1000) and Inventory.ClickItem(Whistle, 'Rumour')) then
    Exit();

  Wait(500, 1000);

  for i := 7 downto 0 do
  begin
    Msg := Chat.GetMessage(i).ToLower();

    if Msg.Contains('moonlight moth') then
      Rumour := MOONLIGHT_MOTH
    else if Msg.Contains('moonlight antelope') then
      Rumour := MOONLIGHT_ANTELOPE
    else if Msg.Contains('sunlight antelope') then
      Rumour := SUNLIGHT_ANTELOPE
    else if Msg.Contains('not have an active') then
      Rumour := NONE
    else
      Continue();

    WriteDebug(ToStr(Rumour));

    if Rumour <> UNSET then
      LoadProfile(Rumour);

    Exit();
  end;
end;

procedure DropJunk();
var
  Slots: TIntegerArray;
begin
  if not Inventory.FindItems(Junk, Slots) then
    Exit();

  if SRL.Dice(85) then
    Inventory.ShiftDrop(Slots, DROP_PATTERN_SNAKE)
  else
    Inventory.RightClickDrop(Slots);

  Wait(250, 500);

  for 0 to 2 do
    WaitUntil(not Inventory.ContainsAny(Junk), 250, 1000);
end;

procedure OnComplete();
begin
  for 0 to 5 do
    if DoQuetzalTravel(qsHUNTER_GUILD, True) then
    begin
      InactivityTimer.Reset();
      Exit();
    end;

  TerminateScript('Failed to return to guild after run');
end;

procedure BirdhouseRun();
begin
  if not OpenBank() then
    Exit();

  BirdhouseRunner.DoRun();
  OnComplete();
end;

procedure FarmRun();
begin
  if not OpenBank() then
    Exit();

  FarmRunner.DoRun();
  OnComplete();
end;

function GetMothState(): EState;
begin
  if (Minimap.GetHPPercent() < 90) and InCombat() then
    Exit(EState.EXIT_BASEMENT);

  if BankMoths then
  begin
    if Inventory.ContainsItem('Butterfly jar') then
    begin
      if IsInZone() and Mainscreen.Bounds.Contains(RSW.GetTileMS(Walk)) then
        Exit(CATCH_FLYING);

      if IsInBasement() then
        Exit(WALK_ZONE);

      Exit(ENTER_BASEMENT);
    end;

    if IsInBasement() then
      Exit(EXIT_BASEMENT);

    if Inventory.IsFull() then
      Exit(RE_STOCK);

    if Inventory.CountItemStack('Coins') > 5 then
      Exit(BUY_JARS);

    Exit(RE_STOCK);
  end;

  if Inventory.IsFull() then
  begin
    if IsInBasement() then
      Exit(EXIT_BASEMENT);

    Exit(RE_STOCK);
  end;

  if IsInZone() and Mainscreen.Bounds.Contains(RSW.GetTileMS(Walk)) then
    Exit(CATCH_FLYING);

  if IsInBasement() then
    Exit(WALK_ZONE);

  Exit(ENTER_BASEMENT);
end;

function GetButterflyState(): EState;
begin
  if IsInZone() then
    Exit(CATCH_FLYING);

  Exit(WALK_ZONE);
end;

function RouteToBank(): EState;
begin
  if IsInBasement() then Exit(EXIT_BASEMENT);
  if IsInGuild() then Exit(RE_STOCK);
  if UseWhistle and Inventory.ContainsItem(Whistle) and (Charges > 0) then Exit(TELEPORT_GUILD);
  if OuterFortis and (RSW.GetMyPos().DistanceTo(OuterQuetzal.Coordinates[0]) < RSW.GetMyPos().DistanceTo(GuildQuetzal.Coordinates[0])) then
    Exit(EState.QUETZAL_GUILD);
  Exit(WALK_GUILD);
end;

function GetAntelopeState(): EState;
var
  TrapStatus: ETrapState;
  Limit: Int32 = 4;
begin
  if not Inventory.ContainsAll(GetToolItems()) then
    Exit(RouteToBank());

  if Inventory.ContainsAny(Antlers) then
    Exit(FLETCH_BOLTS);

  if not Inventory.ContainsItem('Logs') then
    Inc(Limit, 3);

  if Inventory.CountEmptySlots() < Limit then
    Exit(RouteToBank());

  if Minimap.GetHPPercent() < 70 then
    Exit(EAT_FOOD);

  if IsInGuild() and (Inventory.CountItem(Food) < FoodAmount) then
    Exit(RE_STOCK);

  if Profiles[Prey].IsBasement and not IsInBasement() then
    Exit(ENTER_BASEMENT);

  if not Profiles[Prey].IsBasement and IsInBasement() then
    Exit(EXIT_BASEMENT);

  if not IsInZone() then
  begin
    if UseWhistle and Inventory.ContainsItem(Whistle) and (Charges > 0) then
    begin
      if RSW.GetMyPos().DistanceTo(Walk) < RSW.GetMyPos().DistanceTo(Chest.Coordinates[0]) then
        Exit(EState.WALK_ZONE);

      Exit(EState.TELEPORT_OUTER);
    end;

    if OuterFortis then
    begin
      if RSW.GetMyPos().DistanceTo(OuterQuetzal.Coordinates[0]) > RSW.GetMyPos().DistanceTo(GuildQuetzal.Coordinates[0]) then
        Exit(EState.QUETZAL_OUTER);
    end;

    Exit(WALK_ZONE);
  end;

  TrapStatus := GetPitfallState();

  if not Inventory.ContainsItem('Logs') and (TrapStatus in [EMPTY, UNKNOWN]) then
  begin
    if Profiles[Prey].IsBasement then
      Exit(GET_LOGS);

    Exit(CHOP_LOGS);
  end;

  case TrapStatus of
    EMPTY: Exit(BUILD_PITFALL);
    CAUGHT: Exit(CHECK_PITFALL);
    BUILT: Exit(CATCH_PITFALL);
    UNKNOWN: Exit(RECOVER);
  end;

  Exit(IDLE);
end;

procedure SetupSnare();
var
  InitialCount: Int32;
begin
  if not MoveToTile(Trap) then
    Exit();

  InitialCount := Inventory.CountItemStack('Bird snare');

  if Inventory.ClickItem('Bird snare') and WaitUntil(Inventory.CountItemStack('Bird snare') < InitialCount, 500, 2500) then
  begin
    Wait(3500, 5000);

    if SRL.Dice(92) then
      MoveToTile(Walk);
  end else
    WriteDebug('Failed to setup trap!');
end;

procedure HoverSnare();
var
  WalkRect, TrapRect: TRectangle;
  TPA: TPointArray;
  Bds: TBox;
begin
  WalkRect := RSW.GetTileMS(Walk);
  TrapRect := RSW.GetTileMS(Trap);

  if not Mainscreen.Bounds.Contains(WalkRect) and Mainscreen.Bounds.Contains(TrapRect) then
    Exit();

  Bds := TrapRect.Bounds().Expand(2);
  Bds.LimitTo(Mainscreen.Bounds);
  SRL.FindColors(TPA, BuiltColor, Bds);

  if Length(TPA) = 0 then
  begin
      RSClient.Image().DrawTPA(TPA, clWhite);
      Mouse.HumanMove(TPA.Mean());
  end else
    Mouse.HumanMove(TrapRect.Mean());

  Wait(200, 300);
end;

procedure DismantleSnare();
var
  Snares: Int32 := Inventory.CountItemStack('Bird snare');
begin
  HoverSnare();

  if not Mainscreen.ClickHelper(Mouse.Position(), ['Dismantle']) then
  begin
    WriteDebug('Failed to dismantle!');
    Antiban.RandomRotate();
    Exit();
  end;

  if WaitUntil(Snares < Inventory.CountItemStack('Bird snare'), 500, 5000) then
  begin
    Wait(1500, 2500);

    if SRL.Dice(92) then
      SetupSnare();
  end;
end;

procedure CheckSnare();
var
  Exp: Int64 := XPBar.Read();
begin
  HoverSnare();

  if not Mainscreen.ClickHelper(Mouse.Position(), ['Check']) then
  begin
    WriteDebug('Failed to check!');
    Antiban.RandomRotate();
    Exit();
  end;

  if WaitUntil(Exp < XPBar.Read(), 500, 5000) then
  begin
    Wait(1500, 2500);
    SetupSnare();
  end;
end;

function GetCrimsonSwiftState(): EState;
var
  WalkRect, TrapRect: TRectangle;
  TPA: TPointArray;
  Uptext: String;
  Bds: TBox;
begin
  if not SRL.PointInPoly(RSW.GetMyPos(), Zone) then
    Exit(EState.WALK_ZONE);

  if not Inventory.ContainsAll(GetToolItems()) then
    Exit(IDLE);

  WalkRect := RSW.GetTileMS(Walk);
  TrapRect := RSW.GetTileMS(Trap);

  if not Mainscreen.Bounds.Contains(WalkRect) and Mainscreen.Bounds.Contains(TrapRect) then
    Exit(EState.RECOVER);

  Uptext := Mainscreen.GetUpText();
  //WriteDebug('Uptext: ' + Uptext);

  if RSW.GetMyPos().DistanceTo(Walk) > 2 then
    Exit(EState.STEP_SIDE);

  if Uptext.Contains('heck') then
    Exit(EState.CHECK_SNARE);

  if Uptext.Contains('ismantle') then
  begin
    if Uptext.Contains('2 more') then
      Exit(EState.DISMANTLE_SNARE);

    Exit(EState.IDLE);
  end;

  Bds := TrapRect.Bounds().Expand(2);
  Bds.LimitTo(Mainscreen.Bounds);
  SRL.FindColors(TPA, BuiltColor, Bds);

  if Length(TPA) = 0 then
    Exit(EState.SETUP_SNARE);

  Exit(HOVER_SNARE);
end;

function GetRumourState(): EState;
begin
  if Inventory.ContainsAny(Rares) then
  begin
    if IsInBasement() then
      Exit(RETURN_RARE);

    if IsInGuild() then
      Exit(ENTER_BASEMENT);

    if UseWhistle and Inventory.ContainsItem(Whistle) then
      Exit(TELEPORT_GUILD);

    Exit(WALK_GUILD);
  end;

  if Rumour = UNSET then
  begin
    if Inventory.ContainsItem(Whistle) then
      Exit(CHECK_RUMOUR);

    if IsInBasement() then
      Exit(EXIT_BASEMENT);

    Exit(RE_STOCK);
  end;

  case Rumour of
    MOONLIGHT_ANTELOPE, SUNLIGHT_ANTELOPE: Exit(GetAntelopeState());
    MOONLIGHT_MOTH: Exit(GetMothState());
  end;

  if not IsInBasement() then
    Exit(ENTER_BASEMENT);

  Exit(GET_RUMOUR);
end;

function GetState(): EState;
begin
  if not RSClient.IsLoggedIn() then
    Exit(HANDLE_LOGIN);

  if RSInterface.IsOpen() then
    Exit(CLOSE_INTERFACE);

  if Antiban.HasTaskWaiting() then
    Exit(DO_ANTIBAN);

  if (UseWhistle or OuterFortis) and QuetzalInterface.IsOpen() then
    Exit(EState.CLOSE_INTERFACE);

  if Mode = EMode.MAKE_MIXES then
  begin
    if Inventory.ContainsAll(['Pestle and mortar', 'Moonlight moth']) and Inventory.ContainsAny(Meats) then
      Exit(EState.PROCESS_MIXES);

    Exit(EState.RESTOCK_MIXES);
  end;

  if ShouldHop() then
    Exit(HOP_WORLDS);

  if UseWhistle then
  begin
    if Charges = -1 then
    begin
      if Inventory.ContainsItem(Whistle) then
        Exit(EState.CHECK_CHARGES);

      if IsInBasement() then
        Exit(EXIT_BASEMENT);

      Exit(EState.RE_STOCK);
    end;

     if ((Charges = 0) or ((Charges <= 1) and OuterFortis and (IsInGuild() or IsOnRoof()))) then
     begin
      if Inventory.ContainsItem(Whistle) and (Inventory.CountItems(Meats) > 3) then
      begin
        if IsOnRoof() then
          Exit(RECHARGE_WHISTLE);

        Exit(CLIMB_ROOF);
      end;

      if IsOnRoof() then
        Exit(EXIT_ROOF);

      Exit(GET_MEATS);
     end;
  end;

  if IsOnRoof() then
    Exit(EXIT_ROOF);

  if Burying and Inventory.ContainsItem('Big bones') then
    Exit(BURY_BONES);

  if Inventory.ContainsAny(Junk) then
    Exit(DROP_JUNK);

  if FarmRunner.CanDoRun() and IsInGuild() and not Inventory.ContainsAny(Rares) then
    Exit(FARM_RUN);

  if BirdhouseRunner.CanDoRun() and IsInGuild() and not Inventory.ContainsAny(Rares) then
    Exit(BIRDHOUSE_RUN);

  if Minimap.GetHPPercent() < 50 then
  begin
    if Inventory.ContainsItem(Food) then
      Exit(EAT_FOOD);

    if IsInBasement() then
      Exit(EXIT_BASEMENT);

    Exit(RE_STOCK);
  end;

  case Mode of
    EMode.RUBY_HARVESTS, EMode.SUNLIGHT_MOTHS: Exit(GetButterflyState());
    EMode.MOONLIGHT_ANTELOPES, EMode.SUNLIGHT_ANTELOPES: Exit(GetAntelopeState());
    EMode.RUMOURS: Exit(GetRumourState());
    EMode.MOONLIGHT_MOTHS: Exit(GetMothState());
    EMode.CRIMSON_SWIFTS: Exit(GetCrimsonSwiftState());
  end;
end;

procedure Loop();
begin
  Current := GetState();
  RSClient.Image.Clear();

  if not ((Current = Previous) and (Current in [CATCH_FLYING, IDLE])) then
    WriteDebug(ToStr(Current));

  case Current of
    HOP_WORLDS: HopWorlds();
    DO_ANTIBAN: Antiban.DoAntiban(not InCombat(1500), False);
    CLOSE_INTERFACE: RSInterface.Close(50);
    HANDLE_LOGIN: Login.LoginPlayer();

    BUILD_PITFALL: BuildPitfall();
    CHECK_PITFALL: CheckPitfall();
    CATCH_PITFALL: CatchPitfall();

    EState.TELEPORT_GUILD: DoQuetzalTravel(qsHUNTER_GUILD, True);
    EState.TELEPORT_OUTER: DoQuetzalTravel(qsOUTER_FORTIS, True);
    EState.QUETZAL_GUILD: DoQuetzalTravel(qsHUNTER_GUILD, False);
    EState.QUETZAL_OUTER: DoQuetzalTravel(qsOUTER_FORTIS, False);

    CATCH_FLYING: CatchFlying();

    EState.STEP_SIDE: MoveToTile(Walk);
    EState.HOVER_SNARE: HoverSnare();
    EState.CHECK_SNARE: CheckSnare();
    EState.DISMANTLE_SNARE: DismantleSnare();
    EState.SETUP_SNARE: SetupSnare();

    ENTER_BASEMENT: EnterBasement();
    EXIT_BASEMENT: ExitBasement();
    EXIT_ROOF: ExitRoof();

    EState.CHECK_CHARGES: Charges := GetWhistleCharges();

    EState.PROCESS_MIXES: ProcessMixes();
    EState.RESTOCK_MIXES: RestockMixes();

    BIRDHOUSE_RUN: BirdhouseRun();
    FARM_RUN: FarmRun();

    RECHARGE_WHISTLE: RechargeWhistle();
    EState.IDLE: Sleep(1500);

    BURY_BONES: BuryBones();
    WALK_ZONE: WalkZone();
    WALK_GUILD: RSW.WebWalk(Point(534, 432).Random(-2, 2));
    FLETCH_BOLTS: FletchBolts();
    CHECK_RUMOUR: CheckRumour();
    RETURN_RARE: ChatWithWolf();
    GET_RUMOUR: ChatWithWolf();
    DROP_JUNK: DropJunk();
    CHOP_LOGS: ChopLogs();
    GET_LOGS: GetLogs();
    RE_STOCK: Restock();
    BUY_JARS: BuyJars();
    EAT_FOOD: EatFood();
    RECOVER: Recovery();
    CLIMB_ROOF: ClimbRoof();
    GET_MEATS: GetMeats();
  end;

  Previous := Current;
  Wait(100, 400);
  RSClient.Image.Clear();
end;

begin
