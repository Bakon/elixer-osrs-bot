            CATCH_PITFALL, CATCH_FLYING, EXIT_BASEMENT, DROP_JUNK, RECOVER, FARM_RUN, IDLE,
            BIRDHOUSE_RUN, EAT_FOOD, CHECK_RUMOUR, DO_ANTIBAN, HOP_WORLDS, ENTER_BASEMENT,
            GET_RUMOUR, RETURN_RARE, CHOP_LOGS, WALK_GUILD, TELEPORT_GUILD, FLETCH_BOLTS,
