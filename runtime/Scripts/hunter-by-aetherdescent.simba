{$I WaspLib/osr.simba}

procedure TAntiban.BioClick(button: Int32; max: Int32 = 3); override;
var
  i: Int32;
begin
  Mouse.Click(button);
  i := max;
end;

function TRSChat.GetMessage(line: Int32; colors: TIntegerArray = CHAT_MESSAGE_COLORS): String; override;
var
  Active: ERSChatButton := ChatButtons.GetActive();
begin
  if (Active <> ERSChatButton.ALL_CHAT) and (Active <> ERSChatButton.GAME_CHAT)  then
    ChatButtons.Open(ERSChatButton.GAME_CHAT);

  if InRange(Self.GetScrollPosition(), 1, 99) then
    Self.SetScrollPosition(100);

  Result := inherited;
end;

function TRSChat.GetAllMessages(): String;
var
  i: Int32;
begin
  for i := 7 downto 0 do
    Result += Self.GetMessage(i);
end;

function TRSChat.GetRecentMessages(): String;
var
  i: Int32;
begin
  for i := 7 downto 5 do
    Result += Self.GetMessage(i);
end;

function TRSMinimap.SetZoomToPoint(p: TPoint; randomness: Int32 = 0): Boolean; override;
begin
  randomness := 0;
  Result := Self.InZoomRange(p);
end;

function TRSWalker.GetTileMSEx(Me, Loc: TPoint; Height:Double=0; Offx,Offy:Double=0): TRectangle; override;
var
  angle: Double;
  vec: Vector3;
begin
  Loc   := Minimap.Center + (Loc - Me);
  angle := Minimap.GetCompassAngle(False);
  vec   := Vec3(Loc.X,loc.Y).RotateXY(angle, Minimap.Center.X, Minimap.Center.Y);
  Result := Minimap.VectorToMSRect(vec + [-offx, -offy, height], 1, 1, angle);
end;

function TWebGraph.PathBetween(p,q: TPoint; rnd: Double = 0): TPointArray; constref; override;
var
  n1, n2: Int32;
  nodes: TIntegerArray;
begin
  n1 := Self.FindNearestNode(p);
  n2 := Self.FindNearestNode(q);

  nodes := Self.FindPath(n1, n2, rnd);

  if Length(nodes) > 0 then
  begin
    Result += p;
    Result += NodesToPoints(nodes);
    Result += q;
  end else
  begin
    if SRL.Dice(50) then
      Antiban.RandomRotate()
    else
      Mouse.Click(Minimap.Center.Random(25, 25), MOUSE_LEFT);

    Sleep(1500);
  end;
end;

procedure TRSMinimap.DoneMoving();
begin
  for 0 to 1 do
    Self.WaitMoving(False);
end;

procedure TRSBankItemArray.Add(Item: TRSBankItem);
var
  i: Int32;
begin
  for i := 0 to High(Self) do
    if Self[i].Item = Item.Item then
      Exit();
  Self += Item;
end;

function TRSMainscreen.ClickHelper(Pt: TPoint; UpTexts: TStringArray): Boolean;
begin
  if not Mainscreen.Bounds.Contains(Pt) then
    Exit(False);

  Mouse.HumanMove(Pt);

  if WaitUntil(Self.GetUpText().ContainsAny(UpTexts), 50, 750) and SRL.Dice(95) then
  begin
    Mouse.Click(MOUSE_LEFT);
    Exit(True);
  end;

  if Self.GetUpText().Contains('alk') and not Uptexts.Merge().Contains('alk') then
    Exit(False);

  if ChooseOption.Open() then
    Wait(150, 500);

  Result := ChooseOption.Select(UpTexts);
end;

{$SCOPEDENUMS ON}

type
  EBirdhouseState = (IDLE, TRAVEL_VALLEY, TRAVEL_MEADOW, HANDLE_BIRDHOUSE);
  EFarmingState = (TELEPORT_PATCH, WALK_PATCH, CLEAR_PATCH, HARVEST_PATCH, PLANT_PATCH, COMPLETED_PATCH,
                   COMPOST_PATCH, NOTE_ITEMS, FAILED_PATCH, UNSELECT_SLOT, CLOSE_INTERFACE, CHECK_PATCH);
  ETravelMethod = (ARDOUGNE_TELEPORT, FALADOR_TELEPORT, CAMELOT_TELEPORT, HOUSE_TELEPORT, FORTIS_TELEPORT,
                   NONE, VARROCK_TELEPORT, ARDOUGNE_CLOAK, DUELING_RING, FARMING_CAPE, SPIRIT_TREE,
                   ICY_BASALT, STONY_BASALT);
  ECategory = (HERB, ALLOTMENT, FLOWER, GATHER, HOPS);

  TBirdhouseRunner = record
    Birdhouses, Valley, House: TPointArray;
    Timer, Failsafe, Overflow: TCountdown;
    Hillshroom, Valleyshroom: TRSObject;
    Return: TRSBankItemArray;
    Runs, Filled, Xp: Int32;
    Seed, Log: TRSItem;
    Enabled: Boolean;
    RSW: TRSWalker;
  end;

  TPatch = record
    Location, Walk, Leprechaun: TPoint;
    Area, Zone: TPointArray;
    Compost, Done: Boolean;
    Travel: ETravelMethod;
    Category: ECategory;
    Seed: TRSItem;
    Name: String;
  end;

  TFarmRunner = record
    GuildHerb, GuildFruits, GuildBerries, GuildCactus, GuildAllotments,
    CatherbyFlower, CatherbyHerb, CatherbyFruits, CatherbyAllotments,
    HosidiusFlower, HosidiusHerb, HosidiusAllotments, TrollheimHerb,
    VarlamoreHerb, VarlamoreFlower, FaladorHerb, WeissHerb,
    FaladorFlower, ArdougneHerb, ArdougneFlower,
    Enabled, MonasteryBerries, AlkharidCactus,
    VarrockBerries, LumbridgeHops: Boolean;
    Timer, Failsafe, Overflow: TCountdown;
    BattlefieldTree, Rocks: TRSObject;
    AllotmentSeed, HopsSeed: TRSItem;
    Produce, Runes: TRSItemArray;
    GuildTravel: ETravelMethod;
    Return: TRSBankItemArray;
    Patches: array of TPatch;
    Runs, Xp, Limit: Int32;
    Current: TPatch;
    RSW: TRSWalker;
  end;

{$SCOPEDENUMS OFF}

var
  BirdhouseRunner: TBirdhouseRunner;
  FarmRunner: TFarmRunner;

function TScriptForm.CreateChoreSettings(Birdhouses: Boolean = True; Farming: Boolean = True): TTabSheet;
  type TScriptForm = TScriptForm;

  procedure TScriptForm._ToggleVisibility(Sender: TObject);
  const
    BirdhouseComponents = ['birdhouse_logs', 'birdhouse_timer', 'birdhouse_info'];
const
  FarmingComponents = [
    'farm_hosidius_label', 'farm_hosidius_herb', 'farm_hosidius_flower', 'farm_hosidius_allotments',
    'farm_monastery_berries', 'farm_catherby_fruits', 'farm_alkharid_cactus', 'farm_timer',
    'farm_guild_berries', 'farm_guild_cactus', 'farm_varrock_berries', 'farm_lumbridge_hops',
    'farm_guild_fruits', 'farm_label', 'farm_guild_label','farm_guild_herb',
    'farm_varlamore_label','farm_varlamore_herb', 'farm_varlamore_flower',
    'farm_catherby_label', 'farm_catherby_herb', 'farm_catherby_flower',
    'farm_ardougne_label','farm_ardougne_herb', 'farm_ardougne_flower',
    'farm_falador_label','farm_falador_herb', 'farm_falador_flower',
    'farm_guild_allotments', 'farm_catherby_allotments',
    'farm_allotment_seed', 'farm_hops_seed',
    'farm_weiss_herb', 'farm_trollheim_herb'
    ];
  var
    SenderBox, TempBox: TCheckBox;
    Tab: TTabSheet;
    S: String;
  begin
    SenderBox := sender;
    Tab := Self.Tabs[High(Self.Tabs)];

    if SenderBox.GetName().Contains('farm') then
    begin
      FarmRunner.Enabled := SenderBox.IsChecked();

      for S in FarmingComponents do
      begin
        TempBox := Tab.GetChild(ToStr(S + '_panel'));

        if TempBox = nil then
        begin
          TempBox := Tab.GetChild(S);

          if TempBox <> nil then
            TempBox.setVisible(SenderBox.IsChecked())
        end else
          TempBox.setVisible(SenderBox.IsChecked());
      end;
    end;

    if SenderBox.GetName().Contains('birdhouse') then
    begin
      BirdHouseRunner.Enabled := SenderBox.IsChecked();

      for S in BirdhouseComponents do
      begin
        TempBox := Tab.GetChild(ToStr(s + '_panel'));

        if TempBox <> nil then
          TempBox.setVisible(SenderBox.IsChecked());
      end;
    end;
  end;

  procedure TScriptForm._AllotmentSeedChanged(sender: TObject);
  var
    ComboBox: TComboBox := sender;
  begin
    FarmRunner.AllotmentSeed := ComboBox.getText() + ' seed';
  end;

  procedure TScriptForm._HopsSeedChanged(sender: TObject);
  var
    ComboBox: TComboBox := sender;
  begin
    FarmRunner.HopsSeed := ComboBox.getText() + ' seed';
  end;

  procedure TScriptForm._OnCheckBoxChanged(sender: TObject);
  var
    Checkbox: TCheckbox := sender;
    IsChecked: Boolean  := Checkbox.IsChecked();
  begin
    case Checkbox.getName() of
      'farm_hosidius_herb_checkbox': FarmRunner.HosidiusHerb := IsChecked;
      'farm_hosidius_flower_checkbox': FarmRunner.HosidiusFlower := IsChecked;
      'farm_catherby_herb_checkbox': FarmRunner.CatherbyHerb := IsChecked;
      'farm_catherby_flower_checkbox': FarmRunner.CatherbyFlower := IsChecked;
      'farm_falador_herb_checkbox': FarmRunner.FaladorHerb := IsChecked;
      'farm_falador_flower_checkbox': FarmRunner.FaladorFlower := IsChecked;
      'farm_ardougne_herb_checkbox': FarmRunner.ArdougneHerb := IsChecked;
      'farm_ardougne_flower_checkbox': FarmRunner.ArdougneFlower := IsChecked;
      'farm_hosidius_allotments_checkbox': FarmRunner.HosidiusAllotments := IsChecked;
      'farm_monastery_berries_checkbox': FarmRunner.MonasteryBerries := IsChecked;
      'farm_catherby_fruits_checkbox': FarmRunner.CatherbyFruits := IsChecked;
      'farm_guild_herb_checkbox': FarmRunner.GuildHerb := IsChecked;
      'farm_guild_berries_checkbox': FarmRunner.GuildBerries := IsChecked;
      'farm_guild_cactus_checkbox': FarmRunner.GuildCactus := IsChecked;
      'farm_guild_fruits_checkbox': FarmRunner.GuildFruits := IsChecked;
      'farm_varlamore_herb_checkbox': FarmRunner.VarlamoreHerb := IsChecked;
      'farm_varlamore_flower_checkbox': FarmRunner.VarlamoreFlower := IsChecked;
      'farm_lumbridge_hops_checkbox': FarmRunner.LumbridgeHops := IsChecked;
      'farm_varrock_berries_checkbox': FarmRunner.VarrockBerries := IsChecked;
      'farm_alkharid_cactus_checkbox': FarmRunner.AlkharidCactus := IsChecked;
      'farm_guild_allotments_checkbox': FarmRunner.GuildAllotments := IsChecked;
      'farm_weiss_herb_checkbox': FarmRunner.WeissHerb := IsChecked;
      'farm_trollheim_herb_checkbox': FarmRunner.TrollheimHerb := IsChecked;
      'farm_catherby_allotments_checkbox': FarmRunner.CatherbyAllotments := IsChecked;
      'farm_enabled_checkbox', 'birdhouses_enabled_checkbox': Self._ToggleVisibility(Checkbox);
    end;
  end;

  procedure TScriptForm._BirdhouseTimerChanged(Sender: TObject);
  var
    SenderTime: TEdit := Sender;
  begin
    BirdhouseRunner.Timer.Init(SenderTime.GetText().ExtractInteger * ONE_MINUTE);
  end;

  procedure TScriptForm._FarmTimerChanged(Sender: TObject);
  var
    SenderTime: TEdit := Sender;
  begin
    FarmRunner.Timer.Init(SenderTime.GetText().ExtractInteger * ONE_MINUTE);
  end;

  procedure TScriptForm._LogTypeChanged(sender: TObject);
  var
    ComboBox: TComboBox := sender;
  begin
    BirdhouseRunner.Log := ComboBox.getText() + ' logs';
  end;

  function TScriptForm._MakeLabel(Tab: TTabSheet; Bold: TFont; Name, Caption: String; Left, Top: Int32): TLabel;
  begin
    Result.Create(Tab);
    Result.SetFont(Bold);
    Result.SetCaption(Caption);
    Result.SetName(Name);
    Result.SetLeft(TControl.AdjustToDPI(Left));
    Result.SetTop(TControl.AdjustToDPI(Top));
    Result.SetVisible(False);
  end;

  function TScriptForm._MakeCheckbox(Tab: TTabSheet; Name, Caption: String; Left, Top: Int32): TLabeledCheckbox;
  begin
    Result.Create(Tab);
    Result.SetCaption(Caption);
    Result.SetName(Name);
    Result.SetLeft(TControl.AdjustToDPI(Left));
    Result.SetTop(TControl.AdjustToDPI(Top));
    Result.CheckBox.setOnChange(@Self._OnCheckBoxChanged);
    Result.SetVisible(False);
  end;

  procedure TScriptForm._AddRegion(Tab: TTabSheet; Bold: TFont;
    RegionName, Prefix: String; Left, Top: Int32;
    Checkboxes: array of record Caption, Suffix: String; end);
  var
    Entry: record Caption, Suffix: String; end;
    Y: Int32;
  begin
    Self._MakeLabel(Tab, Bold, Prefix + '_label', RegionName, Left, Top);
    Y := Top + 20;
    for Entry in Checkboxes do
    begin
      Self._MakeCheckbox(Tab, Prefix + '_' + Entry.Suffix, Entry.Caption, Left, Y);
      Y += 20;
    end;
  end;

var
  Bold: TFont;
  Tab: TTabSheet;
  cb_Farming, cb_Birdhouses: TLabeledCheckbox;
  combo_UntilBirdhouse, combo_UntilFarm, combo_LogType,
  combo_AllotmentSeed, combo_HopsSeed: TLabeledCombobox;
begin
  Self.AddTab('Chores');
  Result := Self.GetTab('Chores');
  Result.SetToolTip('');
  Tab := Result;

  Bold.Init();
  Bold.setName('Segoe UI Bold');
  Bold.setQuality(fqClearType);

  if Birdhouses then
  begin
    BirdhouseRunner.Log := 'Maple logs';
    BirdhouseRunner.Timer.Init(50 * ONE_MINUTE);

    cb_Birdhouses.Create(Tab);
    cb_Birdhouses.SetFontSize(12);
    cb_Birdhouses.SetCaption('Enable Birdhouse Runs');
    cb_Birdhouses.SetName('birdhouses_enabled');
    cb_Birdhouses.SetLeft(TControl.AdjustToDPI(20));
    cb_Birdhouses.SetTop(TControl.AdjustToDPI(20));
    cb_Birdhouses.CheckBox.setOnChange(@Self._OnCheckBoxChanged);

    combo_UntilBirdhouse.Create(Tab);
    combo_UntilBirdhouse.SetCaption('First run at:');
    combo_UntilBirdhouse.SetName('birdhouse_timer');
    combo_UntilBirdhouse.SetLeft(TControl.AdjustToDPI(20));
    combo_UntilBirdhouse.SetTop(TControl.AdjustToDPI(50));
    combo_UntilBirdhouse.SetStyle(csDropDownList);
    combo_UntilBirdhouse.AddItemArray(['0 minutes', '5 minutes', '15 minutes', '30 minutes', '50 minutes']);
    combo_UntilBirdhouse.SetWidth(90);
    combo_UntilBirdhouse.SetItemIndex(4);
    combo_UntilBirdhouse.Combobox.SetOnChange(@Self._BirdhouseTimerChanged);
    combo_UntilBirdhouse.SetVisible(False);

    combo_LogType.Create(Tab);
    combo_LogType.SetCaption('Birdhouse log:');
    combo_LogType.SetStyle(csDropDownList);
    combo_LogType.AddItemArray(['Oak', 'Willow', 'Teak', 'Maple', 'Mahogany', 'Yew', 'Magic', 'Redwood']);
    combo_LogType.SetLeft(TControl.AdjustToDPI(120));
    combo_LogType.SetTop(TControl.AdjustToDPI(50));
    combo_LogType.SetWidth(90);
    combo_LogType.SetName('birdhouse_logs');
    combo_LogType.SetItemIndex(3);
    combo_LogType.Combobox.SetOnChange(@Self._LogTypeChanged);
    combo_LogType.SetVisible(False);
  end;

  if Farming then
  begin
    FarmRunner.Timer.Init(90 * ONE_MINUTE);
    FarmRunner.AllotmentSeed := 'Snape grass seed';
    FarmRunner.HopsSeed := 'Jute seed';

    cb_Farming.Create(Tab);
    cb_Farming.SetFontSize(12);
    cb_Farming.SetName('farm_enabled');
    cb_Farming.SetCaption('Enable Farming Runs');
    cb_Farming.SetLeft(TControl.AdjustToDPI(20));
    cb_Farming.SetTop(TControl.AdjustToDPI(120));
    cb_Farming.CheckBox.setOnChange(@Self._OnCheckBoxChanged);

    combo_UntilFarm.Create(Tab);
    combo_UntilFarm.SetCaption('First run at:');
    combo_UntilFarm.SetLeft(TControl.AdjustToDPI(20));
    combo_UntilFarm.SetTop(TControl.AdjustToDPI(150));
    combo_UntilFarm.SetStyle(csDropDownList);
    combo_UntilFarm.AddItemArray(['0 minutes', '15 minutes', '45 minutes', '90 minutes']);
    combo_UntilFarm.SetWidth(90);
    combo_UntilFarm.SetName('farm_timer');
    combo_UntilFarm.SetItemIndex(3);
    combo_UntilFarm.Combobox.SetOnChange(@Self._FarmTimerChanged);
    combo_UntilFarm.SetVisible(False);

    combo_AllotmentSeed.Create(Tab);
    combo_AllotmentSeed.SetCaption('Allotment:');
    combo_AllotmentSeed.SetLeft(TControl.AdjustToDPI(20));
    combo_AllotmentSeed.SetTop(TControl.AdjustToDPI(190));
    combo_AllotmentSeed.SetStyle(csDropDownList);
    combo_AllotmentSeed.AddItemArray(['Snape grass', 'Watermelon']);
    combo_AllotmentSeed.SetWidth(90);
    combo_AllotmentSeed.SetName('farm_allotment_seed');
    combo_AllotmentSeed.SetItemIndex(0);
    combo_AllotmentSeed.Combobox.SetOnChange(@Self._AllotmentSeedChanged);
    combo_AllotmentSeed.SetVisible(False);

    combo_HopsSeed.Create(Tab);
    combo_HopsSeed.SetCaption('Hops:');
    combo_HopsSeed.SetLeft(TControl.AdjustToDPI(20));
    combo_HopsSeed.SetTop(TControl.AdjustToDPI(230));
    combo_HopsSeed.SetStyle(csDropDownList);
    combo_HopsSeed.AddItemArray(['Jute', 'Yanillian', 'Flax', 'Hemp', 'Cotton']);
    combo_HopsSeed.SetWidth(90);
    combo_HopsSeed.SetName('farm_hops_seed');
    combo_HopsSeed.SetItemIndex(0);
    combo_HopsSeed.Combobox.SetOnChange(@Self._HopsSeedChanged);
    combo_HopsSeed.SetVisible(False);

    Self._AddRegion(Tab, Bold, 'Falador', 'farm_falador', 130, 150, [['Herb', 'herb'], ['Limpwurt', 'flower']]);
    Self._AddRegion(Tab, Bold, 'Varlamore', 'farm_varlamore', 130, 220, [['Herb', 'herb'], ['Limpwurt', 'flower']]);
    Self._AddRegion(Tab, Bold, 'Ardougne', 'farm_ardougne',  130, 290, [['Herb', 'herb'], ['Limpwurt', 'flower']]);
    Self._AddRegion(Tab, Bold, 'Catherby', 'farm_catherby',  230, 150, [['Herb', 'herb'], ['Limpwurt', 'flower'], ['Allotments', 'allotments']]);
    Self._AddRegion(Tab, Bold, 'Hosidius', 'farm_hosidius',  230, 240, [['Herb', 'herb'], ['Limpwurt', 'flower'], ['Allotments', 'allotments']]);
    Self._AddRegion(Tab, Bold, 'Guild', 'farm_guild', 330, 150, [['Herb', 'herb'], ['Fruit tree', 'fruits'], ['Berries', 'berries'], ['Cactus', 'cactus'], ['Allotments', 'allotments']]);
    Self._AddRegion(Tab, Bold, 'Other', 'farm',  430, 150, [['Catherby fruits', 'catherby_fruits'], ['Monastery berries', 'monastery_berries'], ['Al Kharid cactus',  'alkharid_cactus'],
    ['Varrock berries', 'varrock_berries'], ['Lumbridge hops', 'lumbridge_hops'], ['Weiss herb', 'weiss_herb'], ['Trollheim herb', 'trollheim_herb']]);
  end;

  Bold.Free();
end;

procedure TBirdhouseRunner.WriteDebug(Message: String);
begin
  WriteLn(SRL.TimeStamp() + ':[' + 'Birdhouses' + ']: ' + Message);
end;

procedure TBirdhouseRunner.Init(Items: TRSItemArray; Amounts: TIntegerArray);
var
  i: Int32;
begin
  if not Self.Enabled then
    Exit();

  RSW_ADAPTIVE_SCREEN_TOGGLE_DISTANCES := [0, 0];
  Self.RSW.SetupFromURL('https://i.ibb.co/8L50DgCd/bh137pq.png', 'bh137pq.png');
  Self.RSW.WebGraph.LoadNodesFromString('LwEAAHicNdDZDcQwCATQVqYE7qOWaPtvY8FO/p4woMGPeINbf494gMMGJmDLQSTYeZAMztonAxctHEJbyXwRBOFeBETtTon7QiG1e6KhpC9Ebo/aVwl/UTseBSO+MUy2J3tAL2jAHJNVY+U0qWuVc4jLqia3+umb4Jwrm3vlq3WfUUeft/mCOoMT4iIFfZaGovn3BxvwRSU=');
  Self.RSW.WebGraph.LoadPathsFromString('IgEAAHicTY2LDQQgDEJXYQTB/yzG/dc4anOXS4zgK9RDNHQMTKx7CoR6D98pmL5C32ShhURy37NAjzYY2QLKQjDKAp1kBbulgcPSwQm5wgG6vPMx7Z7IO1aC8ZgEVahBHfIG0WKUzljpejKDDMwfjoBloRI1Hv5lpzMr6fZ3auDAX65k9X4AKuE/5w==');
  Self.RSW.WebGraph.LoadNamesFromString('hAAAAHici1Y2iI0eYAwA8I4ibA==');
  Self.RSW.AdaptiveWalk := True;

  if Length(Items) > 0 then
    for i := 0 to High(Items) do
      Self.Return += TRSBankItem.Setup(Items[i], Amounts[i], False);

  Self.Hillshroom.Setup(8, [[1162, 90]]);
  Self.Hillshroom.SetupUpText(['Mush', 'tree']);
  Self.Hillshroom.Filter.Finder := False;

  Self.Valleyshroom.Setup(8, [[580, 648]]);
  Self.Valleyshroom.SetupUpText(['Mush', 'tree']);
  Self.Valleyshroom.Filter.Finder := False;

  Self.Xp := XPBar.Read();
  Self.Failsafe.Init(5 * ONE_MINUTE);
  Self.Overflow.Init(5 * ONE_MINUTE);

  Self.Birdhouses := [[596, 654], [616, 630], [253, 146], [262, 414]];
  Self.House := [[1125, 67], [1205, 67], [1221, 172], [1112, 171]];
  Self.Valley := [[538, 587], [682, 568], [684, 695], [525, 691]];

  Self.WriteDebug('Initialized with ' + ToStr(Self.Log));
  Self.WriteDebug('First run in ' + SRL.MsToTime(Self.Timer.TimeRemaining(), TTimeFormat.Time_Abbrev));
end;

function TBirdhouseRunner.GetItemList(): TRSBankItemArray;
begin
  Result += TRSBankItem.Setup("Digsite pendant (1)", 1, False);
  Result += TRSBankItem.Setup("Chisel", 1, False);
  Result += TRSBankItem.Setup("Hammer", 1, False);
  Result += TRSBankItem.Setup(Self.Log, 4, False);
end;

procedure TBirdhouseRunner.TravelMeadow();
begin
  if not RSInterface.IsOpen() then
    if not ValleyShroom.Click() then
    begin
      Self.RSW.WalkBlind(Self.Valleyshroom.Coordinates[0].Random(-6, 6));
      Minimap.DoneMoving();

      if not ValleyShroom.Click() then
        Exit();
    end;

  if WaitUntil(RSInterface.IsOpen(), 2000, 12000) then
  begin
    if SRL.Dice(10) then
      Wait(2000, 5000);

    Keyboard.PressKey(VK_4);

    if Keyboard.IsKeyDown(VK_4) then
      Keyboard.KeyUp(VK_4);

    WaitUntil(not SRL.PointInpoly(Self.RSW.GetMyPos(), Self.Valley), 1500, 6000);
  end;
end;

procedure TBirdhouseRunner.TravelValley();
begin
  if not RSInterface.IsOpen() then
    if not Hillshroom.Click() then
    begin
      Self.RSW.WalkBlind(Self.Hillshroom.Coordinates[0].Random(-6, 6));
      Minimap.DoneMoving();

      if not Hillshroom.Click() then
        Exit();
    end;

  if WaitUntil(RSInterface.IsOpen(), 2000, 12000) then
  begin
    if SRL.Dice(10) then
      Wait(2000, 5000);

    Keyboard.PressKey(VK_2);

    if Keyboard.IsKeyDown(VK_2) then
      Keyboard.KeyUp(VK_2);

    WaitUntil(SRL.PointInpoly(Self.RSW.GetMyPos(), Self.Valley), 1500, 6000);
  end;
end;

function TBirdhouseRunner.Interact(Tile: TPoint; Uptext: TStringArray): Boolean;
const
  Colors: Array of TCTS2Color := [CTS2(3755628, 1, 0.01, 0.01), CTS2(6847105, 10, 0.04, 0.16)];
var
  Color: TCTS2Color;
  TPA: TPointArray;
  Rect: TRectangle;
  Area: TBox;
begin
  for 0 to 5 do
  begin
    Rect := Self.RSW.GetTileMS(Tile);
    Area := Rect.Bounds().Expand(18);
    Area.LimitTo(Mainscreen.Bounds);

    for Color in Colors do
    begin
      SRL.FindColors(TPA, Color, Area);

      if Length(TPA) > 0 then
      begin
        if Mainscreen.ClickHelper(TPA.Mean(), Uptext) then
          Exit(True);
      end;
    end;

    if Mainscreen.ClickHelper(Self.RSW.GetTileMS(Tile).Mean(), Uptext) then
      Exit(True);

    Self.WriteDebug('Failed with mean');

    Self.RSW.WalkBlind(Tile.Random(-4, 4));
    Antiban.RandomRotate();
  end;
end;

function TBirdhouseRunner.ResetBirdhouse(Tile: TPoint): Boolean;
var
  Exp: Int64 := XPBar.Read();
begin
  if Self.Interact(Tile, ['eset']) then
    Minimap.DoneMoving();

  WaitUntil(Inventory.ContainsItem('Clockwork') or Chat.HasContinue(), 600, 12000);

  if Chat.GetChatTitle().Contains('will lose') then
    Exit(False);

  if WaitUntil(not Inventory.ContainsItem('Clockwork'), 500, 5000) then
    Wait(800, 1400);

  Result := Exp < XPBar.Read();
end;

function TBirdhouseRunner.FillBirdhouse(Tile: TPoint): Boolean;
var
  Slot, Seeds: Int32;
begin
  if not Inventory.FindItem(Self.Seed, Slot) then
    TerminateScript("No seeds!");

  Seeds := Inventory.CountItemStack(Self.Seed);

  for 0 to 5 do
  begin
    Inventory.SetSelectedSlot(-1);
    if Inventory.SetSelectedSlot(Slot) then
      if Inventory.GetSelectedSlot() = Slot then
        Break();
  end;

  Self.Interact(Tile, ['mpty']);
  Result := WaitUntil(Seeds > Inventory.CountItemStack(Self.Seed), 1500, 6000);
end;

procedure TBirdhouseRunner.HandleBirdhouse();
begin
  if Self.RSW.GetMyPos.DistanceTo(Self.Birdhouses[Self.Filled]) > 20 then
    Self.RSW.WalkBlind(Self.Birdhouses[Self.Filled]);

  Minimap.DoneMoving();

  if Self.ResetBirdhouse(Self.Birdhouses[Self.Filled]) then
    Self.FillBirdhouse(Self.Birdhouses[Self.Filled]);

  Inc(Self.Filled);
end;

function TBirdhouseRunner.ShouldStop(): Boolean;
var
  t: Int32;
begin
  if Self.Filled > 3 then
    Exit(True);

  if not Inventory.ContainsAll(['Chisel', 'Hammer', Self.Seed, Self.Log]) then
    Exit(True);

  t := XPBar.Read();

  if t > Self.XP then
  begin
    Self.XP := t;
    Self.Failsafe.Restart();
  end;

  Result := Self.Failsafe.IsFinished();
end;

function TBirdhouseRunner.GetState(): EBirdhouseState;
begin
  if SRL.PointInPoly(Self.RSW.GetMyPos(), Self.House) then
    Exit(EBirdhouseState.TRAVEL_VALLEY);

  if SRL.PointInPoly(Self.RSW.GetMyPos(), Self.Valley) and (Self.Filled > 1) then
    Exit(EBirdhouseState.TRAVEL_MEADOW);

  Exit(EBirdhouseState.HANDLE_BIRDHOUSE);
end;

function TBirdhouseRunner.TeleportToHill(): Boolean;
begin
  if not WaitUntil(Inventory.ClickItem('Digsite pendant (1)', 'Rub'), 500, 2500) then
    Exit();

  if WaitUntil(Chat.ClickOption('Fossil Island', 50), 500, 5000) then
    Wait(2500, 4000);

  Result := WaitUntil(SRL.PointInPoly(Self.RSW.GetMyPos(), Self.House), 750, 7500);
end;

function TBirdhouseRunner.CanDoRun(): Boolean;
var
  ts: String;
begin
  Result := Self.Enabled and Self.Timer.IsFinished();

  if not Result then
    if Self.Overflow.IsFinished() then
    begin
      ts := SRL.MsToTime(Self.Timer.TimeRemaining(), TTimeFormat.Time_Abbrev);
      Self.WriteDebug('Next run in ' + ts);

      if Self.Runs > 0 then
        Self.WriteDebug(ToStr('Runs completed ', Self.Runs));

      Self.Overflow.Restart();
    end;
end;

procedure TBirdhouseRunner.DoRun();
var
  State: EBirdhouseState;
  cw: PRSWalker;
  Exp, i: Int64;
begin
  if not Self.WithdrawNextRun() then
    Exit();

  cw := ScriptWalker;

  if not Self.TeleportToHill() then
    Exit();

  ScriptWalker := @Self.RSW;
  Exp := XPBar.Read();

  repeat
    if not RSClient.IsLoggedIn() then
      Login.LoginPlayer();

    if RSInterface.IsOpen() then
      RSInterface.Close(50);

    Minimap.DoneMoving();
    State := Self.GetState();
    Self.WriteDebug(ToStr(State));

    case State of
      EBirdhouseState.HANDLE_BIRDHOUSE: Self.HandleBirdhouse();
      EBirdhouseState.TRAVEL_MEADOW: Self.TravelMeadow();
      EBirdhouseState.TRAVEL_VALLEY: Self.TravelValley();
    end;
  until Self.ShouldStop();

  WaitUntil(Chat.ClickContinue(50), 500, SRL.NormalRange(2000, 3000));
  ScriptWalker := cw;
  Self.WriteDebug('Finished run ' + ToStr(Inc(Self.Runs)));
  Self.WriteDebug('Gained ' + ToStr(XPBar.Read() - Exp) + ' experience on this run');
  Self.Timer.Init(Random(55, 60) * ONE_MINUTE);
  Self.Filled := 0;
  RSClient.Image().Clear();

  for i := 0 to High(Antiban.Tasks) do
    Antiban.Tasks[i].Countdown.Restart();
end;

function TBirdhouseRunner.WithdrawNextRun(): Boolean;
const
  Seeds: TRSItemArray := [
      'Barley seed', 'Hammerstone seed', 'Potato seed', 'Asgarnian seed', 'Potato seed',
      'Yanillian seed', 'Marigold seed', 'Rosemary seed', 'Onion seed', 'Cabbage seed',
      'Jute seed', 'Tomato seed', 'Krandorian seed', 'Wildblood seed', 'Sweetcorn seed'
     ];
var
  Item: TRSBankItem;
  S: TRSItem;
begin
  if not Bank.IsOpen() then
    Exit(False);

  if Inventory.CountEmptySlots() <> 28 then
    Bank.DepositAll();

  if not WaitUntil(Inventory.CountEmptySlots() > 20, 500, 2500) then
    Exit(False);

  for Item in Self.GetItemList() do
  begin
    if WaitUntil(Bank.ContainsItem(Item.Item), 150, 750) then
      if Bank.WithdrawItem(Item, False) then
        WaitEx(550, 50);

    if not WaitUntil(Inventory.ContainsItem(Item.Item), 250, 1000) then
    begin
      Self.WriteDebug("Failed to withdraw: " + ToStr(Item.Item));
      Exit(False);
    end;
  end;

  for S in Seeds do
  begin
    if Bank.ContainsItem(S) then
    begin
      Self.Seed := S;
      Item := TRSBankItem.Setup(S, 40, False);

      if Bank.WithdrawItem(Item, False) then
        Break();
    end else
      Continue();

    Self.WriteDebug('No birdhouse seeds found');
    Exit(False);
  end;

  if Length(Self.Return) > 0 then
    for Item in Self.Return do
      if Bank.WithdrawItem(Item, False) then
        WaitEx(600, 75);

  Wait(500, 1750);
  Result := Bank.Close(50);
end;

function TFarmRunner.ShouldStop(): Boolean;
var
  t: Int32;
begin
  t := XPBar.Read();

  if t > Self.XP then
  begin
    Self.XP := t;
    Self.Failsafe.Restart();
  end;

  Result := Self.Failsafe.IsFinished();
end;

procedure TFarmRunner.WriteDebug(Message: String);
begin
  WriteLn(SRL.TimeStamp() + ':[' + 'Farming' + ']: ' + Message);
end;

function TFarmRunner.CanDoRun(): Boolean;
var
  ts: String;
begin
  Result := Self.Enabled and Self.Timer.IsFinished();

  if not Result then
    if Self.Overflow.IsFinished() then
    begin
      ts := SRL.MsToTime(Self.Timer.TimeRemaining(), TTimeFormat.Time_Abbrev);
      Self.WriteDebug('Next run in ' + ts);

      if Self.Runs > 0 then
        Self.WriteDebug(ToStr('Runs completed ', Self.Runs));

      Self.Overflow.Restart();
    end;
end;

function TPatch.IsVisible(): Boolean;
begin
  Result := Mainscreen.Bounds.Contains(FarmRunner.RSW.GetTileMS(Self.Location));
end;

function TPatch.Find(out Mean: TPoint): Boolean;
var
  Tile: TRectangle := FarmRunner.RSW.GetTileMS(Self.Location);
begin
  Result := Mainscreen.Bounds.Contains(Tile);

  if Result then
    Mean := Tile.Mean();
end;

function TPatch.Inspect(out Text: String): Boolean;
var
  Messages: String := Chat.GetAllMessages();
  Pt: TPoint;
begin
  if not Self.Find(Pt) then
    Exit(False);

  Result := Mainscreen.ClickHelper(Pt, ['nspect']);

  if Result then
  begin
    WaitUntil(Messages <> Chat.GetAllMessages(), 500, 5500);
    Wait(1000, 1500);
    Text := Chat.GetRecentMessages();
  end;
end;

function TPatch.Hover(): Boolean;
var
  Pt: TPoint;
begin
  Result := Self.Find(Pt);

  if Result then
    Mouse.HumanMove(Pt);
end;

function TFarmRunner.GetCompostCount(): Int32;
var
  P: TPatch;
begin
  for P in Self.Patches do
    if P.Compost then
      Inc(Result);
end;

function TFarmRunner.FindLeprechaun(out Pt: TPoint): Boolean;
const
  Trollheim: TCTS2Color := CTS2(3438625, 6, 0.54, 3.05);
  Normal: TCTS2Color := CTS2(2845243, 13, 0.08, 1.51);
var
  TPA: TPointArray;
  C: TCTS2Color;
  Bounds: TBox;
begin
  if Self.Current.Name.Contains('TROLLHEIM') then
    C := Trollheim
  else
    C := Normal;

  Bounds := Self.RSW.GetTileMS(Self.Current.Leprechaun).Expand(8).Bounds();
  Bounds.LimitTo(Mainscreen.Bounds);

  if Bounds.Area() > 1 then
  begin
    SRL.FindColors(TPA, C, Bounds);

    if Length(TPA) > 0 then
    begin
      Pt := TPA.Mean();
      Result := True;
    end;
  end;
end;

procedure TFarmRunner.NoteItems();
var
  Slots: TIntegerArray;
  Pt: TPoint;
begin
  if not Inventory.FindItems(Produce, Slots) then
    Exit();

  if not Self.FindLeprechaun(Pt) then
    if Self.RSW.WalkBlind(Self.Current.Leprechaun + [4, 4]) then
      Minimap.DoneMoving();

  if Self.FindLeprechaun(Pt) then
  begin
    Inventory.SetSelectedSlot(Slots[0]);

    if Mainscreen.ClickHelper(Pt, ['Tool']) then
      WaitUntil(Chat.GetChat().Contains('banknote'), 500, 8500);
  end else
    Antiban.RandomRotate();

  Wait(500, 1750);

  if Inventory.ContainsItem('Bucket') then
    Inventory.ShiftDrop(['Bucket'], DROP_PATTERN_SNAKE);
end;

procedure TFarmRunner.ClearPatch();
var
  Pt: TPoint;
begin
  if not Self.Current.Find(Pt) then
    Exit();

  if Mainscreen.ClickHelper(Pt, ['Dead']) then
  begin
    WaitEx(4500, 500);
    Self.Current.Hover();
    WaitUntil(Mainscreen.IsUpText(['patch', 'Patch', 'Allotment']), 500, 12500);
  end;
end;

procedure TFarmRunner.CompostPatch();
var
  Exp: Int32 := XPBar.Read();
  Slots: TIntegerArray;
  Pt: TPoint;
begin
  if not Inventory.FindItems(['Ultracompost', 'Bottomless compost bucket'], Slots) then
    Exit();

  if Inventory.SetSelectedSlot(Slots[0]) and Self.Current.Find(Pt) then
    if Mainscreen.ClickHelper(Pt, ['>']) then
      Self.Current.Done := WaitUntil(Exp < XPBar.Read(), 550, 10000);
end;

procedure TFarmRunner.PlantPatch();
var
  Seeds: Int32 := Inventory.CountItemStack(Self.Current.Seed);
  Pt: TPoint;
begin
  if ((Self.Current.Category = ECategory.ALLOTMENT) and (Seeds < 3)) or (Seeds < 1) then
  begin
    Self.Current.Done := True;
    Exit();
  end;

  if Inventory.SetSelectedItem(Self.Current.Seed) and Self.Current.Find(Pt) then
    if Mainscreen.ClickHelper(Pt, ['patch', 'Patch', 'Allotment']) then
    begin
      if WaitUntil(Seeds > Inventory.CountItemStack(Self.Current.Seed), 500, 7500) then
        WaitEx(750, 150);

      if Self.Current.Category = ECategory.FLOWER then
        Self.Current.Done := True
      else
        Self.CompostPatch();
    end;
end;

// returns true if the patch is ready to be re-planted
function TFarmRunner.WaitHarvest(): Boolean;
var
  Exp: Int64 := XPBar.Read();
begin
  if Self.Current.Category = ECategory.FLOWER then
    Exit(WaitUntil(Exp < XPBar.Read(), 1500, 7500));

  WaitUntil(Exp < XPBar.Read(), 750, 15000);

  if Self.Current.Hover() then
    WaitUntil(Mainscreen.IsUpText(['patch', 'llotment', 'Patch', 'Chop', 'Clear']) or Inventory.IsFull(), 750, 32500);

  Result := Mainscreen.IsUpText(['patch', 'llotment', 'Patch', 'Chop', 'Clear']);

  if Result and (Self.Current.Category = ECategory.GATHER) then
  begin
    Self.Current.Done := True;
    Result := False;
  end;
end;

procedure TFarmRunner.HarvestPatch();
var
  Pt: TPoint;
begin
  if not Self.Current.Find(Pt) then
    Exit();

  if Mainscreen.ClickHelper(Pt, ['Pick', 'Harvest']) then
    if Self.WaitHarvest() then
      Self.PlantPatch();
end;

procedure TFarmRunner.CheckPatch();
var
  Exp: Int64 := XPBar.Read();
  Pt: TPoint;
begin
  if not Self.Current.Find(Pt) then
    Exit();

  if Mainscreen.ClickHelper(Pt, ['health', 'Check']) then
    if WaitUntil(Exp < XPBar.Read(), 750, 15500) then
      WaitEx(1500, 500);
end;

procedure TFarmRunner.TeleportPatch();
const
  ARDOUGNE_CLOAKS: TRSItemArray = ['Ardougne cloak 1', 'Ardougne cloak 2', 'Ardougne cloak 3', 'Ardougne cloak 4'];
  FARMING_CAPES: TRSItemArray = ['Farming cape', 'Farming cape(t)'];
var
  Item: TRSItem;
begin
  if SRL.PointInPoly(Self.RSW.GetMyPos(), Self.Current.Area) then
    Exit();

  if not WaitUntil(Chat.ClickContinue(50), 500, SRL.NormalRange(1000, 1500)) then
    Minimap.WaitMoving();

  case Self.Current.Travel of
    ETravelMethod.HOUSE_TELEPORT: Magic.CastSpell(ERSSpell.TELEPORT_TO_HOUSE, 'Outside');
    ETravelMethod.CAMELOT_TELEPORT: Magic.CastSpell(ERSSpell.CAMELOT_TELEPORT);
    ETravelMethod.FALADOR_TELEPORT: Magic.CastSpell(ERSSpell.FALADOR_TELEPORT);
    ETravelMethod.ARDOUGNE_TELEPORT: Magic.CastSpell(ERSSpell.ARDOUGNE_TELEPORT);
    ETravelMethod.VARROCK_TELEPORT: Magic.CastSpell(ERSSpell.VARROCK_TELEPORT);
    ETravelMethod.FORTIS_TELEPORT: Magic.CastSpell(ERSSpell.CIVITAS_ILLA_FORTIS_TELEPORT);

    ETravelMethod.ARDOUGNE_CLOAK:
      for Item in ARDOUGNE_CLOAKS do
        if Inventory.ClickItem(Item, 'Monastery') then
          Break();

    ETravelMethod.FARMING_CAPE:
      if Inventory.ContainsAny(FARMING_CAPES) then
      begin
        for Item in FARMING_CAPES do
          if Inventory.ClickItem(Item, 'Teleport') then
            Break();
      end else
        Equipment.ClickSlot(ERSEquipmentSlot.CAPE, 'Teleport');

    ETravelMethod.SPIRIT_TREE:
      if SRL.PointInPoly(Self.RSW.GetMyPos(), [[1388, 546], [1789, 545], [1787, 762], [1394, 754]]) then
      begin
        if not Self.RSW.WebWalk(Self.BattlefieldTree.Coordinates[0].Random(2, 6)) then
          Self.RSW.WalkBlind(Self.BattlefieldTree.Coordinates[0].Random(2, 6));

        Minimap.DoneMoving();

        if Self.BattlefieldTree.Click() then
        begin
          if not WaitUntil(RSInterface.IsOpen(), 750, 12500) then
            Exit();

          WaitEx(550, 200);

          Keyboard.PressKey(VK_B);

          if Keyboard.IsKeyDown(VK_B) then
            Keyboard.KeyUp(VK_B);
        end;
      end else
        for Item in ARDOUGNE_CLOAKS do
          if Inventory.ClickItem(Item, 'Monastery') then
            Break();

    ETravelMethod.DUELING_RING:
      if Inventory.ClickItem('Ring of dueling(1)', 'Rub') then
        WaitUntil(Chat.ClickOption('Emir', 50), 500, 2500);

    ETravelMethod.STONY_BASALT:
    begin
      if Inventory.ClickItem('Stony basalt') then
        WaitEx(2750, 250);

      if not SRL.PointInPoly(Self.RSW.GetMyPos(), Self.Current.Area) then
       if Rocks.Click() then
         WaitEx(3750, 250);
    end;

    ETravelMethod.ICY_BASALT:
      if Inventory.ClickItem('Icy basalt') then
        WaitEx(750, 250);
  end;

  Wait(500, 1750);
  WaitUntil(Inventory.Open(), 1000, 2000);

  if not WaitUntil(SRL.PointInPoly(Self.RSW.GetMyPos(), Self.Current.Area), 1000, 5000) then
  begin
    Self.WriteDebug('Never arrived at area, uptext: ' + Mainscreen.GetUpText());
    if SRL.Dice(50) then
      Antiban.RandomRotate()
    else
      Mouse.RandomMovement();
  end;
end;

procedure TFarmRunner.WalkPatch();
var
  Pos, Dest: TPoint;
  Dist: Double;
begin
  Pos := Self.RSW.GetMyPos();
  Dest := Self.Current.Walk;
  Dist := Pos.DistanceTo(Dest);

  if (Dist < 100) or not Self.RSW.WebWalk(Dest) then
    RSW.WalkBlind(Dest);

  Self.RSW.MakePointVisible(Self.Current.Location);
end;

procedure TFarmRunner._AddPatch(_Name: String; _Cat: ECategory; _Travel: ETravelMethod; _Seed: TRSItem; _Compost: Boolean; _Loc, _Lep, _Walk: TPoint; _Area, _Zone: TPointArray);
var
  p: TPatch;
begin
  p.Name := _Name;
  p.Category := _Cat;
  p.Travel := _Travel;
  p.Seed := _Seed;
  p.Compost := _Compost;
  p.Location := _Loc;
  p.Leprechaun := _Lep;
  p.Walk := _Walk;
  p.Area := _Area;
  p.Zone := _Zone;
  Self.Patches += p;
end;

procedure TFarmRunner.Init(Items: TRSItemArray; Amounts: TIntegerArray);
var
  i: Int32;
begin
  if not Self.Enabled then
    Exit();

  if Self.GuildHerb or Self.GuildCactus or Self.GuildFruits or Self.GuildBerries or Self.GuildAllotments then
  begin
    for 0 to 3 do
    begin
      WaitUntil(Stats.Open(), 100, 600);
      i := Stats.GetLevel(ERSSkill.FARMING, False);

      if i > -1 then
        Break();

      Stats.Open();
      Wait(100, 500);
    end;

    if i < 5 then
      TerminateScript('Failed to read farming level');

    if i = 99 then
     Self.GuildTravel := ETravelMethod.FARMING_CAPE
    else
      Self.GuildTravel := ETravelMethod.SPIRIT_TREE;

    Self.WriteDebug('Guild travel: ' + ToStr(Self.GuildTravel));
  end else
    Self.GuildTravel := ETravelMethod.NONE;

  Self.Runes := ['Air rune', 'Law rune'];

  if WaitUntil(Equipment.Open(), 200, 1000) then
  begin
    if Equipment.ContainsItem('Tome of water') then
      Self.WriteDebug('We have a tome of water equipped, skipping water runes')
    else
      Self.Runes += 'Water rune';

    if Equipment.ContainsItem(3053) then
      Self.WriteDebug('We have a lava battlestaff equipped, skipping earth and fire runes')
    else
      Self.Runes += ['Fire rune', 'Earth rune'];
  end;

  Self.Produce := ['Grimy guam leaf', 'Grimy marrentill', 'Grimy tarromin', 'Grimy harralander',
                   'Poison ivy berries', 'Jute fibre', 'Cotton boll', 'Hemp', 'Yanillian hops',
                   'Grimy torstol', 'Grimy ranarr weed', 'Grimy toadflax', 'Grimy irit leaf',
                   'Grimy avantoe', 'Grimy dwarf weed', 'Grimy kwuarm', 'Grimy snapdragon',
                   'Grimy cadantine', 'Grimy lantadyme', 'Grimy huasca', 'Potato cactus',
                   'Limpwurt root', 'Watermelon', 'Snape grass', 'Cactus spine', 'Flax',
                   'Papaya fruit', 'Coconut', 'Dragonfruit', 'White berries'];

  if Length(Items) > 0 then
    for i := 0 to High(Items) do
      Self.Return += TRSBankItem.Setup(Items[i], Amounts[i], False);

  if Self.WeissHerb then
    Self._AddPatch('WEISS HERB', ECategory.HERB, ETravelMethod.ICY_BASALT, 'Guam seed', True,
                   [3854, 592], [3852, 610], [3852, 598],
                   [[3803, 570], [3871, 568], [3870, 633], [3804, 631]],
                   [[3842, 589], [3868, 589], [3869, 617], [3841, 616]]);

  if Self.TrollheimHerb then
    Self._AddPatch('TROLLHEIM HERB', ECategory.HERB, ETravelMethod.STONY_BASALT, 'Guam seed', True,
                   [3738, 1220], [3736, 1258], [3744, 1226],
                   [[3795, 1227], [3819, 1204], [3751, 1175], [3705, 1178], [3691, 1240], [3773, 1258]],
                   [[3719, 1209], [3760, 1204], [3756, 1269], [3714, 1268]]);

  if Self.HosidiusHerb then
    Self._AddPatch('HOSIDIUS HERB', ECategory.HERB, ETravelMethod.HOUSE_TELEPORT, 'Guam seed', True,
                   [3032, 1330], [3042, 1324], [3026, 1324],
                   [[2916, 1179], [3219, 1181], [3230, 1535], [2921, 1538]],
                   [[3012, 1307], [3043, 1307], [3043, 1339], [3012, 1340]]);

  if Self.HosidiusFlower then
    Self._AddPatch('HOSIDIUS FLOWER', ECategory.FLOWER, ETravelMethod.HOUSE_TELEPORT, 'Limpwurt seed', False,
                   [3016, 1314], [3042, 1324], [3026, 1324],
                   [[2916, 1179], [3219, 1181], [3230, 1535], [2921, 1538]],
                   [[3012, 1307], [3043, 1307], [3043, 1339], [3012, 1340]]);

  if Self.HosidiusAllotments then
  begin
    Inc(Self.Limit, 20);
    Self._AddPatch('HOSIDIUS ALLOTMENT S', ECategory.ALLOTMENT, ETravelMethod.HOUSE_TELEPORT, Self.AllotmentSeed, True,
                   [3018, 1328], [3042, 1324], [3026, 1324],
                   [[2916, 1179], [3219, 1181], [3230, 1535], [2921, 1538]],
                   [[3012, 1307], [3043, 1307], [3043, 1339], [3012, 1340]]);
    Self._AddPatch('HOSIDIUS ALLOTMENT N', ECategory.ALLOTMENT, ETravelMethod.HOUSE_TELEPORT, Self.AllotmentSeed, True,
                   [3034, 1316], [3042, 1324], [3026, 1324],
                   [[2916, 1179], [3219, 1181], [3230, 1535], [2921, 1538]],
                   [[3012, 1307], [3043, 1307], [3043, 1339], [3012, 1340]]);
  end;

  if Self.ArdougneHerb then
    Self._AddPatch('ARDOUGNE HERB', ECategory.HERB, ETravelMethod.ARDOUGNE_TELEPORT, 'Guam seed', True,
                   [1862, 98], [1868, 72], [1856, 92],
                   [[1523, 22], [1993, 26], [1994, 519], [1523, 514]],
                   [[1846, 75], [1874, 75], [1875, 106], [1846, 107]]);

  if Self.ArdougneFlower then
    Self._AddPatch('ARDOUGNE FLOWER', ECategory.FLOWER, ETravelMethod.ARDOUGNE_TELEPORT, 'Limpwurt seed', False,
                   [1846, 98], [1868, 72], [1856, 92],
                   [[1523, 22], [1993, 26], [1994, 519], [1523, 514]],
                   [[1846, 75], [1874, 75], [1875, 106], [1846, 107]]);

  if Self.FaladorHerb then
    Self._AddPatch('FALADOR HERB', ECategory.HERB, ETravelMethod.FALADOR_TELEPORT, 'Guam seed', True,
                   [568, 404], [546, 430], [562, 418],
                   [[157, 84], [638, 88], [644, 539], [163, 536]],
                   [[537, 396], [575, 397], [576, 435], [537, 435]]);

  if Self.FaladorFlower then
    Self._AddPatch('FALADOR FLOWER', ECategory.FLOWER, ETravelMethod.FALADOR_TELEPORT, 'Limpwurt seed', False,
                   [552, 420], [546, 430], [562, 418],
                   [[157, 84], [638, 88], [644, 539], [163, 536]],
                   [[537, 396], [575, 397], [576, 435], [537, 435]]);

  if Self.CatherbyHerb then
    Self._AddPatch('CATHERBY HERB', ECategory.HERB, ETravelMethod.CAMELOT_TELEPORT, 'Guam seed', True,
                   [2546, 208], [2552, 198], [2540, 202],
                   [[2304, 134], [2814, 146], [2809, 441], [2306, 339]],
                   [[2529, 192], [2557, 193], [2557, 222], [2530, 223]]);

  if Self.CatherbyFlower then
    Self._AddPatch('CATHERBY FLOWER', ECategory.FLOWER, ETravelMethod.CAMELOT_TELEPORT, 'Limpwurt seed', False,
                   [2530, 208], [2552, 198], [2540, 202],
                   [[2304, 134], [2814, 146], [2809, 441], [2306, 339]],
