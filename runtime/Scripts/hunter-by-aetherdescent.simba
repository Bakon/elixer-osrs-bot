function TFarmRunner.GetItemList(): TRSBankItemArray;
var
  Patch: TPatch;
  Item: TRSItem;
  i: Int32;
begin
  for Item in Self.Runes do
    Result.Add(TRSBankItem.Setup(Item, Bank.QUANTITY_ALL_BUT_ONE, False));

  if Self.MonasteryBerries or (Self.GuildTravel = ETravelMethod.SPIRIT_TREE) then
    for i := 1 to 4 do
      Result.Add(TRSBankItem.Setup('Ardougne cloak ' + ToStr(i), 1, False));

  if Self.TrollheimHerb then
    Result += TRSBankItem.Setup("Stony basalt", 1, False);

  if Self.WeissHerb then
    Result += TRSBankItem.Setup("Icy basalt", 1, False);

  Result += TRSBankItem.Setup("Spade", 1, False);
  Result += TRSBankItem.Setup("Magic secateurs", 1, False);
  Result += TRSBankItem.Setup("Seed dibber", 1, False);
  Result += TRSBankItem.Setup('Farming cape(t)', 1, False);
  Result += TRSBankItem.Setup('Farming cape', 1, False);

  if Self.AlkharidCactus then
    Result += TRSBankItem.Setup('Ring of dueling(1)', 1, False);

  for Patch in Self.Patches do
    case Patch.Category of
      ECategory.HERB: Result.Add(TRSBankItem.Setup('Guam seed', Bank.QUANTITY_ALL, False));
      ECategory.ALLOTMENT: Result.Add(TRSBankItem.Setup(Self.AllotmentSeed, Bank.QUANTITY_ALL, False));
      ECategory.FLOWER: Result.Add(TRSBankItem.Setup('Limpwurt seed', Bank.QUANTITY_ALL, False));
      ECategory.HOPS: Result.Add(TRSBankItem.Setup(Self.HopsSeed, Bank.QUANTITY_ALL, False));
    end;
end;

function TFarmRunner.WithdrawReturnItems(): Boolean;
var
  Item: TRSBankItem;
begin
  if Length(Self.Return) > 0 then
  begin
    for Item in Self.Return do
      if not (ToStr(Item.Item).Contains('rune') and Inventory.ContainsItem(Item.Item)) then
        Bank.WithdrawItem(Item, False);

    if not WaitUntil(Inventory.ContainsItem(Item.Item), 500, 2500) then
      Exit(False);

    WaitEx(750, 150);
  end;

  Wait(500, 1500);
  Exit(True);
end;

function TFarmRunner.WithdrawNextRun(): Boolean;
var
  Item: TRSBankItem;
  i: Int32;
begin
  if not WaitUntil(Bank.IsOpen(), 250, 1000) then
    Exit(False);

  if Inventory.CountEmptySlots() <> 28 then
    Bank.DepositAll();

  if not WaitUntil(Inventory.CountEmptySlots() > 20, 250, 1250) then
    Exit(False);

  for Item in Self.GetItemList() do
    if not WaitUntil(Bank.ContainsItem(Item.Item), 150, 750) then
    begin
      if ToStr(Item.Item).Contains('seed') then
      begin
        for i := High(Self.Patches) downto 0 do
          if Self.Patches[i].Seed = Item.Item then
            Delete(Self.Patches, i, 1);

        if Length(Self.Patches) = 0 then
        begin
          Self.Enabled := False;
          Self.WriteDebug('Out of all seeds, disabling runs');
          Exit(False);
        end;
      end;
    end else
      if Bank.WithdrawItem(Item, False) then
      begin
        WaitUntil(not ChooseOption.IsOpen(), 200, 1000);
        WaitEx(500, 50);
      end;

  if not WaitUntil(Inventory.ContainsItem('Spade'), 250, 1250) then
    Exit(False);

  if Self.GetCompostCount() > 0 then
  begin
    if Bank.ContainsItem('Ultracompost') then
      Item := TRSBankItem.Setup('Ultracompost', Self.GetCompostCount(), False);

    if Bank.ContainsItem('Bottomless compost bucket') then
      Item := TRSBankItem.Setup('Bottomless compost bucket', 1, False);

    if Bank.WithDrawItem(Item, False) then
      WaitEx(950, 250);
  end;

  if not Self.WithdrawReturnItems() then
    Exit(False);

  Result := Bank.Close(50);
end;

function TFarmRunner.GetState(): EFarmingState;
var
  Uptext, ChatText: String;
begin
  if not SRL.PointInPoly(Self.RSW.GetMyPos(), Self.Current.Zone) then
  begin
    if SRL.PointInPoly(Self.RSW.GetMyPos(), Self.Current.Area) then
      Exit(EFarmingState.WALK_PATCH);

    Exit(EFarmingState.TELEPORT_PATCH);
  end;

  if Inventory.GetSelectedSlot() <> -1 then
    Exit(EFarmingState.UNSELECT_SLOT);

  if Inventory.ContainsAny(Self.Produce) then
    Exit(EFarmingState.NOTE_ITEMS);

  if Self.Current.Done then
    Exit(EFarmingState.COMPLETED_PATCH);

  if not Self.Current.IsVisible() then
    Exit(EFarmingState.WALK_PATCH);

  if Self.Current.Hover() then
  begin
    Uptext := Mainscreen.GetUpText();

    if Uptext.ContainsAny(['e lily']) then
      Exit(EFarmingState.COMPLETED_PATCH);

    if Uptext.ContainsAny(['Pick', 'Harvest', 'ass plant']) then
      Exit(EFarmingState.HARVEST_PATCH);

    if Uptext.ContainsAny(['Check', 'health']) then
      Exit(EFarmingState.CHECK_PATCH);

    if Self.Current.Category = ECategory.GATHER then
      Exit(EFarmingState.COMPLETED_PATCH);

    if Uptext.ContainsAny(['dead', 'Dead']) then
      Exit(EFarmingState.CLEAR_PATCH);

    if Uptext.ContainsAny(['iseased', 'Cure', 'e lily']) then
      Exit(EFarmingState.COMPLETED_PATCH);

    if Uptext.ContainsAny(['patch', 'llotment', 'Patch']) then
      Exit(EFarmingState.PLANT_PATCH);

    if Self.Current.Inspect(ChatText) then
    begin
      if ChatText.ContainsAny(['e lily']) then
        Exit(EFarmingState.COMPLETED_PATCH);

      if ChatText.ContainsAny(['fully grown']) then
        Exit(EFarmingState.HARVEST_PATCH);

      if ChatText.ContainsAny(['diseased']) then
        Exit(EFarmingState.COMPLETED_PATCH);

      if ChatText.ContainsAny(['dead']) then
        Exit(EFarmingState.CLEAR_PATCH);

      if ChatText.ContainsAny(['is empty']) then
        Exit(EFarmingState.PLANT_PATCH);

      if ChatText.ContainsAny(['Check', 'health']) then
        Exit(EFarmingState.CHECK_PATCH);

      if Self.Current.Compost and ChatText.ContainsAny(['not been']) then
      begin
        if Inventory.ContainsAny(['Bottomless compost bucket', 'Ultracompost']) then
          Exit(EFarmingState.COMPOST_PATCH);

        Exit(EFarmingState.COMPLETED_PATCH);
      end;

      if ChatText.ContainsAny(['growing']) then
        Exit(EFarmingState.COMPLETED_PATCH);
    end;
  end;

  Exit(EFarmingState.FAILED_PATCH);
end;

procedure TFarmRunner.FailedPatch(Count: Int32);
begin
  if Count mod 2 = 0 then
    Antiban.RandomRotate()
  else
    Self.RSW.WalkBlind(Self.Current.Walk.Random(-4, 4));
end;

procedure TFarmRunner.DoRun();
var
  TotalAttempts, Attempts, i: Int32;
  State: EFarmingState;
  cw: PRSWalker;
  Exp: Int64;
begin
  if not Self.WithdrawNextRun() then
    Exit();

  cw := ScriptWalker;
  ScriptWalker := @Self.RSW;
  Exp := XPBar.Read();

  for Self.Current in Self.Patches do
  begin
    Attempts := 0;

    repeat
      if not RSClient.IsLoggedIn() then
        Login.LoginPlayer();

      Minimap.DoneMoving();
      State := Self.GetState();

      Inc(Attempts);
      Inc(TotalAttempts);

      Self.WriteDebug(ToStr(Attempts) + ' ' + Self.Current.Name + ': ' + ToStr(State));

      if XPBar.EarnedXP() then
        Attempts := 0;

      if Attempts = 7 then
        State := EFarmingState.COMPLETED_PATCH;

      case State of
        EFarmingState.CLOSE_INTERFACE: RSInterface.Close(50);
        EFarmingState.UNSELECT_SLOT: Inventory.SetSelectedSlot(-1);
        EFarmingState.TELEPORT_PATCH: Self.TeleportPatch();
        EFarmingState.WALK_PATCH: Self.WalkPatch();
        EFarmingState.NOTE_ITEMS: Self.NoteItems();
        EFarmingState.CLEAR_PATCH: Self.ClearPatch();
        EFarmingState.HARVEST_PATCH: Self.HarvestPatch();
        EFarmingState.COMPOST_PATCH: Self.CompostPatch();
        EFarmingState.PLANT_PATCH: Self.PlantPatch();
        EFarmingState.FAILED_PATCH: Self.FailedPatch(Attempts);
        EFarmingState.CHECK_PATCH: Self.CheckPatch();
      end;

    until Self.ShouldStop() or (State = EFarmingState.COMPLETED_PATCH) or (TotalAttempts > Self.Limit);

    Self.Current.Done := False;
  end;

  ScriptWalker := cw;
  Self.WriteDebug('Finished run ' + ToStr(Inc(Self.Runs)));
  Self.WriteDebug('Gained ' + ToStr(XPBar.Read() - Exp) + ' experience on this run');
  Self.Timer.Init(Random(85, 90) * ONE_MINUTE);

  for i := 0 to High(Antiban.Tasks) do
    Antiban.Tasks[i].Countdown.Restart();
end;

type
  EAnimal = (NONE, UNSET, MOONLIGHT_MOTH, SUNLIGHT_ANTELOPE, MOONLIGHT_ANTELOPE, SUNLIGHT_MOTH,
             RUBY_HARVEST, CRIMSON_SWIFT);
