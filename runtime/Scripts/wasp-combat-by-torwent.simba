procedure TCombatConfig.Run(); override;
var
  tab: TTabSheet;
  m: ERSMonster;
  current, str: String;
begin
  Self.Setup('Wasp Combat');
  Self.Config.Setup('wasp-combat');

  Self.Start.setOnClick(@Self.StartScript);

  Self.AddTab('Script Settings');
  tab := Self.Tabs[High(Self.Tabs)];

  Self.CreateAccountManager(tab);

  with Self.MonsterSelector do
  begin
    Create(tab);
    SetCaption('Monster:');
    SetLeft(TControl.AdjustToDPI(30));
    SetTop(TControl.AdjustToDPI(180));
    SetStyle(csDropDownList);

    if Self.Config.Has('monster') then
      current := Self.Config.GetString('monster')
    else
      current := MonsterName;

    for m := ERSMonster(0) to High(ERSMonster) do
    begin
      str := ToStr(m).Replace('_', ' ').SentenceCase();
      AddItem(str);
      if str = current then
        SetItemIndex(Ord(m));
    end;
    SetWidth(TControl.AdjustToDPI(200));
    Combobox.SetOnChange(@Self.MonsterSelectorOnChange);
  end;

  with Self.MapSelector do
  begin
    Create(tab);
    SetCaption('Locations (no need to choose):');
    SetLeft(Self.MonsterSelector.GetLeft());
    SetTop(Self.MonsterSelector.GetBottom() + TControl.AdjustToDPI(15));
    SetWidth(TControl.AdjustToDPI(200));
    SetStyle(csDropDownList);
  end;

  with Self.MinHealthEdit do
  begin
    Create(tab);
    SetCaption('Minimum health:');
    SetLeft(Self.MonsterSelector.GetRight() + TControl.AdjustToDPI(60));
    SetTop(Self.MonsterSelector.GetTop());

    if Self.Config.Has('min_health') then
      SetText(ToStr(Self.Config.GetInt('min_health') + Random(-3,3)))
    else
      SetText(ToStr(PlayerMinHealth));
  end;

  with Self.MinPrayerEdit do
  begin
    Create(tab);
    SetCaption('Minimum prayer:');
    SetLeft(Self.MinHealthEdit.GetRight() + TControl.AdjustToDPI(15));
    SetTop(Self.MinHealthEdit.GetTop());

    if Self.Config.Has('min_prayer') then
      SetText(ToStr(Self.Config.GetInt('min_prayer') + Random(-3,3)))
    else
      SetText(ToStr(PlayerMinPrayer));
  end;

  with Self.SlayerStopCheckbox do
  begin
    Create(tab);
    SetCaption('Stop after slayer task');
    SetLeft(Self.MinHealthEdit.GetLeft());
    SetTop(Self.MapSelector.GetTop() + TControl.AdjustToDPI(5));

    if Self.Config.Has('task_stop') then
      SetChecked(Self.Config.GetBoolean('task_stop'))
    else
      SetChecked(StopAfterSlayerTask);
  end;

  with Self.SafeSpotCheckbox do
  begin
    Create(tab);
    SetCaption('Starting tile as safe spot');
    SetLeft(Self.SlayerStopCheckbox.GetLeft());
    SetTop(Self.SlayerStopCheckbox.GetBottom() + TControl.AdjustToDPI(15));

    if Self.Config.Has('safe_spot') then
      SetChecked(Self.Config.GetBoolean('safe_spot'))
    else
      SetChecked(SafeSpot);
  end;

  Self.CreateLootManager();
  Self.MonsterSelectorOnChange(Self.MonsterSelector.Combobox);
  Self.CreateAlchemyPanel();
  Self.CreateAntibanManager();
  Self.CreateWaspLibSettings();
  Self.CreateAPISettings();

  inherited;
end;

var
  CombatConfig: TCombatConfig;
{$ENDIF}

begin
  {$IFDEF SCRIPT_GUI}
  CombatConfig.Run();
  {$ENDIF}
  CombatScript.Run(WLSettings.MaxActions, WLSettings.MaxTime);
end.
