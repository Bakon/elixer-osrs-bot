var
  MonsterName: String = 'Hellhound';
  Chunks: array of TMapChunk  := [Chunk(Box(25,157,26,156), 0)];
  DownScale: Int32 := 8;
  PlayerMinHealth := Random(20, 35);
  PlayerMinPrayer := Random(15, 35);
  LootValue = 5000;
  StopAfterSlayerTask = True;
  SafeSpot = False;

type
  TCombatScript = record(TBaseWalkerScript)
    State: ECombatState;

    AlchEnabled: Boolean;
  end;

procedure TCombatScript.SetupMonster();
var
  all: TNPCV2Array;
  npc: TNPCV2;
begin
  all := NPCs.GetAll(MonsterName);
  all.Reduce();
  npc := all[0];

  if SafeSpot then
    CombatHandler.Setup(True, npc, LootValue, 4000, Map.Position())
  else
    CombatHandler.Setup(True, npc, LootValue, 2000);

  if not CombatHandler.AutoRetaliateEnabled then
    Combat.SetAutoRetaliate(True);

  CombatHandler.MinHitPoints := Round(
                                  Antiban.GetUniqueInt(
                                    PlayerMinHealth,
                                    PlayerMinHealth - 7,
                                    PlayerMinHealth + 10));
  CombatHandler.MinPrayPoints := Round(
                                  Antiban.GetUniqueInt(
                                    PlayerMinPrayer,
                                    PlayerMinPrayer - 7,
                                    PlayerMinPrayer + 10));

  Options.SetNPCAttackOption(EAttackOption.ALWAYS_LEFT_CLICK);
end;

procedure TCombatScript.Init(maxActions: UInt32; maxTime: UInt64); override;
begin
  Antiban.Skills := [
    ESKILL.ATTACK, ESKILL.STRENGTH, ESKILL.DEFENCE, ESKILL.HITPOINTS,
    ESKILL.RANGE, ESKILL.MAGIC, ESKILL.TOTAL
  ];

  Antiban.MinZoom := 5;
  Antiban.MaxZoom := 20;

  inherited;

  if StopAfterSlayerTask then
  begin
    Antiban.Skills += ESKILL.SLAYER;
    Antiban.AddTask(11 * ONE_MINUTE, @Antiban.CheckSlayerHelm);
    Antiban.AddTask(16 * ONE_MINUTE, @Antiban.CheckSlayerBracelet);
  end;

  Self.AlchEnabled := Magic.CanActivate(ESpell.HIGH_LEVEL_ALCHEMY);
  Map.SetupChunks(Chunks, DownScale);
  NPCs.Setup(Map.NPCs(), @Map.Walker);

  Self.SetupMonster();
end;

procedure TCombatScript.Terminate();
begin
  if not StopAfterSlayerTask then Exit;

  if Chat.FindMessage('9 tasks', [CHAT_COLOR_BLACK]) then
  begin
    if (Inventory.Open() and Inventory.ClickItem('Rada''s blessing 4..3', 'Mount')) or
        Equipment.ClickItem('Rada''s blessing 4..3', 'Mount') then
      Exit;
  end;

  if
      Equipment.Open() and (
        Equipment.ClickItem('Karamja gloves 4', 'Duradel') or
        Equipment.ClickItem('Karamja gloves 3', 'Gem')
      ) or Inventory.Open() and (
        Inventory.ClickItem('Karamja gloves 4', 'Duradel') or
        Inventory.ClickItem('Karamja gloves 3', 'Gem')
      )
    then
      Exit;

  Magic.CastSpell(ESpell.VARROCK_TELEPORT);
end;


procedure TCombatScript.Run(maxActions: UInt32; maxTime: UInt64);
begin
  Self.Init(maxActions, maxTime);

  repeat
    if WL.Activity.IsFinished() then
    begin
      WriteLn('No activity detected in 5 minutes! Shutting down.');
      Break;
    end;

    Self.State := CombatHandler.GetState();
    Self.TotalActions := CombatHandler.TotalKills;
    Self.SetAction(ToStr(Self.State));

    if Chat.FindMessage('superior foe', [CHAT_COLOR_LIGHT_RED]) then
    begin
      ShowBalloonHint('Superior foe appeared!', 'A superior foe has appeared!', 3000, TBalloonFlags.bfInfo);
      SaveScreenshot('slayer/superior/superior', False); //saves superior screenshots to add their colors in the future.
      //This will take a lot of screenshots. Which is more or less intended to hopefully get several angles.
    end;

    CombatHandler.DoActions(Self.State);

    if StopAfterSlayerTask and CombatHandler.SlayerTaskFinished then
    begin
      WriteLn 'Slayer task finished.';
      SaveScreenshot('slayer/slayerdone', Chat.Bounds);
      Self.Terminate();
      Break;
    end;

    Self.DoAntiban();
    ChatButtons.Open(EChatButton.GAME_CHAT);
  until Self.ShouldStop();

  WaitUntil(not MainScreen.WaitInCombat(2400), 500, 15000);  //wait to be out of combat.
  Logout.ClickLogout();
end;

var
  CombatScript: TCombatScript;

function TLogout.ClickLogout(attempts: Int32 = 5; tryTime: Int32 = 20000): Boolean; override;
begin
  while not CombatHandler.WaitCombatEnd() do
    Wait(100);

  Wait(12000);
  WL.Activity.Pause();
  Result := inherited;
end;


function TMMDot._HoverHelper(attempts: Int32; trackTarget: Boolean): Boolean; override;
var
  shouldExit: Boolean;
  attempt: Int32;
  atpa: T2DPointArray;
  tpa: TPointArray;
  angle: Double;
begin
  if Self.Filter.MinimapDot and (Minimap.GetDots(Self.DotType) = []) then
    Exit;

  Result := Self._UpTextCheck(shouldExit);
  if shouldExit then
    Exit;

  for attempt := 0 to attempts do
  begin
    if Self.Find(atpa) then
    begin
      if attempt < 2 then
        tpa := atpa[0]
      else if Length(atpa) > (attempt - 2) then
        tpa := atpa[attempt - 2]
      else
        tpa := atpa.RandomValue();

      if trackTarget then
        Mouse.OnMovingEx := @Self._UpdateTarget;

      if Self.DotType = EMinimapDot.ITEM then
        Mouse.Move(tpa.Mean())
      else
        Mouse.Move(tpa.RandomValue());

      if not Self.Filter.UpText then
        Exit(True);
    end;

    if MainScreen.IsUpText(Self.UpText) then
      Exit(True);

    //will rotate the screen for the last attempt if hasn't hovered properly yet
    if (Self.DotType <> EMinimapDot.ITEM) and (attempt = (attempts - 1)) then
    begin
      angle := Minimap.GetCompassAngle() + Random(-50, 50);
      Minimap.SetCompassAngle(angle, 10);
    end;
  end;
end;


{$IFDEF SCRIPT_GUI}
type
  TCombatConfig = record(TScriptForm)
    MonsterSelector, MapSelector: TLabeledCombobox;
    MinHealthEdit, MinPrayerEdit: TLabeledEdit;
    SlayerStopCheckbox, SafeSpotCheckbox: TCheckbox;
    Config: TConfigJSON;
  end;

procedure TCombatConfig.StartScript(sender: TObject); override;
begin
  MonsterName  := Self.MonsterSelector.GetText();

  PlayerMinHealth := StrToInt(Self.MinHealthEdit.getText());
  PlayerMinPrayer := StrToInt(Self.MinPrayerEdit.getText());

  StopAfterSlayerTask := Self.SlayerStopCheckbox.IsChecked();
  SafeSpot := Self.SafeSpotCheckbox.IsChecked();

  Self.Config.Put('min_health', PlayerMinHealth);
  Self.Config.Put('min_prayer', PlayerMinPrayer);
  Self.Config.Put('loot_value', LootValue);
  Self.Config.Put('task_stop', StopAfterSlayerTask);
  Self.Config.Put('safe_spot', SafeSpot);

  inherited;
end;

