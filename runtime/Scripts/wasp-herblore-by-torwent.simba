var
  CurrentBank: EBankChunk = EBankChunk.GRAND_EXCHANGE;
  MixPotion: TItem := 'Super combat potion';
  UseChemNecklace: Boolean := False;

type
  EHerbalistState = (
    HOVER_BANK, OPEN_BANK,
    WITHDRAW_VIALS, WITHDRAW_INGREDIENTS, WITHDRAW_NECKLACE,
    WEAR_NECKLACE, DEPOSIT_POTIONS, DEPOSIT_INVENTORY,

    OPEN_COLLECT, HANDLE_COLLECT, CLOSE_INTERFACE,

    DO_POTIONS, HANDLE_MAKE, WAIT_MIXING,

    LEVEL_UP, CLOSE_CONTEXT,

    OUT_OF_SUPPLIES, END_SCRIPT
  );

  THerbalist = record(TBaseBankScript)
    State: EHerbalistState;

    Vial, Necklace: TBankItem;
    Ingredients, Potions: TBankItemArray;

    DoseValue, NeckChargeValue, ActionProfit3Dose, ActionProfit4Dose,
    NecklaceChargeCount: Int32;

    Mixing, NecklaceEquipped, CapeEquipped, GogglesEquipped: Boolean;
  end;

//Setup the potion we are going to make.
procedure THerbalist.SetupPotions();
var
  itemStr: String := ToStr(MixPotion);
begin
  if itemStr.Contains('(unf)') then
  begin
    if itemStr.Contains('blood') then
      Self.Vial := Self.Vial.Setup('Vial of blood', 14)
    else
      Self.Vial := Self.Vial.Setup('Vial of water', 14);

    if itemStr.Contains('Guam') then
      Self.Ingredients := [['Guam leaf', 14, False]]
	  else if itemStr.Contains('Marrentill') then
      Self.Ingredients := [['Marrentill', 14, False]]
	  else if itemStr.Contains('Tarromin') then
      Self.Ingredients := [['Tarromin', 14, False]]
	  else if itemStr.Contains('Harralander') then
      Self.Ingredients := [['Harralander', 14, False]]
	  else if itemStr.Contains('Ranarr') then
      Self.Ingredients := [['Ranarr weed', 14, False]]
	  else if itemStr.Contains('Toadflax') then
      Self.Ingredients := [['Toadflax', 14, False]]
	  else if itemStr.Contains('Irit') then
      Self.Ingredients := [['Irit leaf', 14, False]]
	  else if itemStr.Contains('Avantoe') then
      Self.Ingredients := [['Avantoe', 14, False]]
	  else if itemStr.Contains('Kwuarm') then
      Self.Ingredients := [['Kwuarm', 14, False]]
	  else if itemStr.Contains('Snapdragon') then
      Self.Ingredients := [['Snapdragon', 14, False]]
    else if itemStr.Contains('Cadantine') then
      Self.Ingredients := [['Cadantine', 14, False]]
	  else if itemStr.Contains('Lantadyme') then
      Self.Ingredients := [['Lantadyme', 14, False]]
	  else if itemStr.Contains('Dwarf weed') then
      Self.Ingredients := [['Dwarf weed', 14, False]]
	  else if itemStr.Contains('Torstol') then
      Self.Ingredients := [['Torstol', 14, False]];

    Self.Potions := [[MixPotion, 14]];
    UseChemNecklace := False;
    Exit;
  end;

  if itemStr.Contains('Attack potion') then
	begin
		Self.Vial := Self.Vial.Setup('Guam potion (unf)', 14);
		Self.Ingredients := [['Eye of newt', 14, False]];
	end

	else if itemStr.Contains('Antipoison') then
