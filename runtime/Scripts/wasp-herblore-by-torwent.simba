{$IFNDEF SCRIPT_CHAIN}
begin
  {$IFDEF SCRIPT_GUI}
  HerbalistConfig.Run();
  {$ENDIF}
  Herbalist.Run(WLSettings.MaxActions, WLSettings.MaxTime);
end.
{$ENDIF}
