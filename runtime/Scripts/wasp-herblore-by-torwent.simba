procedure THerbalistConfig.StartScript(sender: TObject); override;
begin
  CurrentBank := EBankChunk(Self.BankSelector.GetItemIndex());
  MixPotion := Self.PotionSelector.GetText();
  UseChemNecklace := Self.ChemNeckState.IsChecked();

  Self.Config.Put('potion', ToStr(MixPotion));
  Self.Config.Put('neck', UseChemNecklace);

  inherited;
end;

procedure THerbalistConfig.Run(); override;
var
  tab: TTabSheet;
begin
  Self.Setup('Wasp Herblore');
  Self.Config.Setup('wasp-herblore');

  if Self.Config.Has('potion') then
    MixPotion := Self.Config.GetString('potion');
  if Self.Config.Has('neck') then
    UseChemNecklace := Self.Config.GetBoolean('neck');

  Self.Start.setOnClick(@Self.StartScript);

  Self.AddTab('Script Settings');
  tab := Self.Tabs[High(Self.Tabs)];

  Self.CreateAccountManager(tab);

  Self.BankSelector := Self.CreateBankSettingsV2(tab, [50, 200], [0,0]);
  Self.PotionSelector.Create(tab, 'Potion:', 'Pick your type of potion.', [0, 30], [0,0], [Self.BankSelector.GetLeft(), Self.BankSelector.GetBottom()], True);
  Self.PotionSelector.AddItemArray(POTION_STRINGS);
  Self.PotionSelector.SetItemIndex(Self.PotionSelector.ComboBox.getItems().IndexOf(ToStr(MixPotion)));

  Self.ChemNeckState.Create(tab, 'Necklace of chemistry:', 'Will you be using a necklave of chemistry?', [20, 0], [200,0], [Self.PotionSelector.GetRight(), Self.PotionSelector.GetTop()], True);
  Self.ChemNeckState.SetChecked(UseChemNecklace);

  Self.CreateAntibanManager();
  Self.CreateWaspLibSettings();
  Self.CreateAPISettings();

  inherited
end;

var
  HerbalistConfig: THerbalistConfig;
