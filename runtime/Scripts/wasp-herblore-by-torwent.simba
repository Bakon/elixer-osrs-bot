  begin
		Self.Vial := Self.Vial.Setup('Lava scale shard', Bank.QUANTITY_ALL);
		Self.Ingredients := [['Super antifire potion(4)', 27, False]];
	end;

  UseChemNecklace := UseChemNecklace and not itemStr.Contains('(4)');

  if itemStr.Contains('Super combat potion') then
    Self.Potions := [[itemStr + '(4)', 7], ['Vial', 14]]
  else if itemStr.ContainsAny(['(1)', '(2)', '(3)', '(4)']) then
  begin
    itemStr := itemStr.Before('(');
    Self.Potions := [
      [itemStr + '(1)', Bank.QUANTITY_ALL],
      [itemStr + '(2)', Bank.QUANTITY_ALL],
      [itemStr + '(3)', Bank.QUANTITY_ALL],
      [itemStr + '(4)', Bank.QUANTITY_ALL]
    ];
  end
  else if itemStr.ContainsAny(['Divine', 'Extended']) or (itemStr = 'Anti-venom') then
    Self.Potions := [[itemStr + '(4)', Bank.QUANTITY_ALL]]
  else if itemStr.ContainsAny(['Super antifire', 'venom+']) then
    Self.Potions := [[itemStr + '(4)', 14]]
  else if itemStr.Contains('Weapon poison') then
    Self.Potions := [[itemStr, Bank.QUANTITY_ALL]]
  else
    Self.Potions := [[itemStr + '(3)', 14], [itemStr + '(4)', 14]];
end;

procedure THerbalist.UpdateHerbs();
var
  herbStr: String;
  grimyHerbStr: String;
  id: Int32;
begin
  herbStr := ToStr(Ingredients[0].Item);
  grimyHerbStr := 'Grimy ' + herbStr.Lower();
  for id in ItemFinder.GetItemIDs(grimyHerbStr) do
    ItemFinder.AddItemName(herbStr, ToStr(id));
end;

//Init function that sets up all variables the way we need them to start the script. It's also where the previous setup procedures are called.
procedure THerbalist.Init(maxActions: UInt32; maxTime: UInt64); override;
var
  productCost: Int32;
  ingredient: TBankItem;
  potionStr: String;
begin
  Antiban.Skills := [ESKILL.HERBLORE, ESKILL.TOTAL];
  Antiban.MinZoom := 15;
  Antiban.MaxZoom := 85;

  inherited;

  Map.SetupChunk(CurrentBank.Get());
  Objects.Setup(Map.Objects(), @Map.Walker);
  NPCs.Setup(Map.NPCs(), @Map.Walker);

  ItemFinder.Similarity := 0.9999;
  Self.SetupPotions();
  Self.Necklace := Self.Necklace.Setup('Amulet of chemistry', 1);

  productCost := ItemData.GetAverage(Self.Vial.Item);

  for ingredient in Self.Ingredients do
    productCost += ItemData.GetAverage(ingredient.Item);

  potionStr := ToStr(Self.Potions[0].Item);

  if potionStr.Contains('Prayer') then
    Self.DoseValue := Round(ItemData.GetAverage(2434) / 4)
  else if Length(Self.Potions) > 1 then
    Self.DoseValue := Round(ItemData.GetAverage(Self.Potions[1].Item) / 4)
  else
    Self.DoseValue := Round(ItemData.GetAverage(Self.Potions[0].Item) / 4);
  Self.NeckChargeValue := Round(ItemData.GetAverage(Necklace.Item) / 5);

  Self.ActionProfit3Dose := ((Self.DoseValue * 3) - productCost);

  Self.GogglesEquipped := Equipment.ContainsItem('Prescription goggles');

  if UseChemNecklace then
  begin
    Self.ActionProfit4Dose := ((Self.DoseValue * 4) - productCost - Self.NeckChargeValue);
    Self.NecklaceEquipped := Equipment.ContainsItem(Self.Necklace.Item);
    Self.CheckCharges();
  end;

  Self.CapeEquipped := Equipment.ContainsAny(['Herblore cape', 'Herblore cape(t)']);

  if Self.CapeEquipped then
    Self.UpdateHerbs();
end;



//Check if we have all ingredients.
function THerbalist.HasIngredients(): Boolean;
var
  ingredient: TBankItem;
  itemArray: TItemArray;
begin
  for ingredient in Self.Ingredients do
    itemArray += ingredient.Item;

  Result := Inventory.ContainsAll(itemArray);
end;

//Check if we have our finished potion.
function THerbalist.HasPotions(): Boolean;
var
  potion: TBankItem;
begin
  for potion in Self.Potions do
    if Inventory.ContainsItem(potion.Item) then
      Exit(True);

  Result := False;
end;

//Check if we have any 4 dosed unfinished potion (due to the necklace of chemistry so we can count the charges on our necklace later).
function THerbalist.Has4DosePotion(): Boolean;
var
  Slots: TIntegerArray;
begin
  Result := Inventory.FindItem(Potions[1].Item, Slots);
end;


//Check if we have a chemistry necklace in the inventory.
function THerbalist.HasNecklace(): Boolean;
begin
  Result := Inventory.ContainsItem(Necklace.Item);
end;

//Wear necklace of chemistry.
function THerbalist.WearNecklace(): Boolean;
begin
  if Inventory.ClickItem(Necklace.Item, 'Wear') then
  begin
    Wait(200);
    Result := WaitUntil(not Self.HasNecklace, 100, 2000);
  end;

  if Result then
    NecklaceChargeCount := 5;
end;

//Count the necklace charges by counting the potions with 4 doses in your inventory.
function THerbalist.CheckNecklace(): Boolean;
var
  potCount: Int32;
begin
  potCount := Inventory.CountItem(Self.Potions[1].Item);
  Result := 0 < (Self.NecklaceChargeCount - potCount);
  Self.NecklaceEquipped := Result;
end;

//Check the necklace charges.
function THerbalist.CheckCharges(): Boolean;
var
  str: String;
begin
  if GameInterface.IsOpen() then
    GameInterface.Close();

  Self.NecklaceEquipped := Equipment.ContainsItem(Self.Necklace.Item);

  if not Self.NecklaceEquipped then
    Exit;

  if Equipment.ClickItem(Necklace.Item) then
    Self.NecklaceEquipped := False;

  if Inventory.Open and WaitUntil(Inventory.ClickItem(Necklace.Item, 'Break'), 100, 2000) then
  begin
    WaitUntil('Status' in (str := Chat.GetChatTitle()), 300, 2000);
    str := str.After('Status: ').Before(' charges left.');
    Self.NecklaceChargeCount := StrToInt(str);
  end;
  if Inventory.ClickItem(Self.Necklace.Item) then
    WaitUntil(not Inventory.ContainsItem(Self.Necklace.Item), 300, 2000);

  Result := True;
end;


//Withdraw an array of TBankItem.
function THerbalist.Withdraw(bankItems: array of TBankItem): Boolean; overload;
var
  item: TBankItem;
begin
  for item in bankItems do
    if not Self.Withdraw(item) then
      Exit(False);

  Result := True;
end;

//Deposit items.
function THerbalist.Deposit(): Boolean;
var
  dose3Count, dose4Count: Int32;
begin
  dose3Count := Inventory.CountItem(Self.Potions[0].Item);
  if Length(Self.Potions) > 1 then
    dose4Count := Inventory.CountItem(Self.Potions[1].Item);

  if Self.GogglesEquipped or (MixPotion = 'Super combat potion') then
    Result := Bank.DepositAll()
  else
    Result := Self.DepositItems(Self.Potions);

  if WaitUntil(not Self.HasPotions(), 100, 2000) then
  begin
    Self.TotalActions += (dose3Count + dose4Count);
    Self.TotalProfit += ((dose3Count * Self.ActionProfit3Dose) + (dose4Count * Self.ActionProfit4Dose));
    Self.NecklaceChargeCount -= dose4Count;
  end;
end;

//Handle the collect box screen.
function THerbalist.HandleCollectBox(): Boolean; overload;
var
  ingredient: TBankItem;
  arr: TItemArray;
begin
  for ingredient in Self.Ingredients do
    arr += ingredient.Item;

  Result := Self.HandleCollectBox(arr);
end;


//Use a vial item with an ingredient item.
function THerbalist.DoPotion(): Boolean;
var
  PotionStr: String := ToStr(Potions[0].Item);
  count: Int32;
begin
  count := Inventory.CountItem(Potions[0].Item);

  if PotionStr.ContainsAny(['Super combat', 'Super anti', 'venom', 'Extended', 'Divine']) or SRL.Dice(50) or Self.CapeEquipped then
    Inventory.Use(Vial.Item, Ingredients[0].Item)
  else
    Inventory.Use(Ingredients[0].Item, Vial.Item);

  Result := WaitUntil(Make.IsOpen() or (Self.Mixing := (Inventory.CountItem(Potions[0].Item) > count)), 300, 3000);
end;

//Handle the make menu.
function THerbalist.HandleMake(): Boolean;
begin
  Result := Make.Select(0, Make.QUANTITY_ALL, Antiban.BioDice(EBioBehavior.KEYBOARD_CHAT_CHANCE));
  if Result then
    Self.Mixing := WaitUntil(not Make.IsOpen(), 100, 2000);
end;


//Check if we are mixing potions.
function THerbalist.IsMixing(waitTime: Int32 = 3000): Boolean;
  function _CountPotions(): Int32;
  var
    i: Int32;
  begin
    for i := 0 to High(Self.Potions) do
      Result += Inventory.CountItem(Self.Potions[i].Item);
  end;
var
  count: Int32;
begin
  count := _CountPotions();
  Result := Self.HasIngredients() and WaitUntil(XPBar.EarnedXP() or (count < _CountPotions()), 300, waitTime);

  if Result then
    WL.Activity.Restart();
end;

//Wait while we are mixing potions.
function THerbalist.WaitMixing(): Boolean;
begin
  Self.Mixing := Self.IsMixing();
  Result := Self.Mixing;

  if Result then
    WL.Activity.Restart()
  else
    if Self.HasIngredients() then
      Self.NecklaceEquipped := Equipment.ContainsItem(Self.Necklace.Item);
end;


//Get the current script state and decide what to do next.
function THerbalist.GetState(): EHerbalistState;
begin
  if WL.Activity.IsFinished() then
    Exit(EHerbalistState.END_SCRIPT);

  if ChooseOption.IsOpen() then
    Exit(EHerbalistState.CLOSE_CONTEXT);

  if Chat.LeveledUp() then
  begin
    Self.Mixing := False;
    Exit(EHerbalistState.LEVEL_UP);
  end;

  if Make.IsOpen() then
  begin
    Self.Mixing := False;
    Exit(EHerbalistState.HANDLE_MAKE);
  end;

  if GameInterface.IsOpen() then
  begin
    Self.Mixing := False;
    Self.HoveringBank := False;

    if Bank.IsOpen() then
    begin
      if Self.HasPotions then
        Exit(EHerbalistState.DEPOSIT_POTIONS);

      if UseChemNecklace and not Self.CheckNecklace() then
      begin
        if Self.HasNecklace then
          Exit(EHerbalistState.WEAR_NECKLACE);

        Exit(EHerbalistState.WITHDRAW_NECKLACE);
      end;

      if Self.BankEmpty or (Inventory.ContainsItem(Self.Vial.Item) and Self.HasIngredients) then
        Exit(EHerbalistState.CLOSE_INTERFACE);

      if not Inventory.ContainsItem(Self.Vial.Item) then
        Exit(EHerbalistState.WITHDRAW_VIALS);

      if not Self.HasIngredients() then
        Exit(EHerbalistState.WITHDRAW_INGREDIENTS);
    end;

    if CollectBox.IsOpen() then
    begin
      if Self.CollectEmpty then
        Exit(EHerbalistState.CLOSE_INTERFACE);

      Exit(EHerbalistState.HANDLE_COLLECT);
    end;

    Exit(EHerbalistState.CLOSE_INTERFACE);
  end;

  if Inventory.ContainsItem(Self.Vial.Item) and Self.HasIngredients then
  begin
    if Self.Mixing then
    begin
      if not Self.HoveringBank then
      begin
        Self.CountItemsLeft(Ingredients[0].Item);

        if Self.ShouldHoverBank() then
          Exit(EHerbalistState.HOVER_BANK);

        Exit(EHerbalistState.WAIT_MIXING);
      end;

      Exit(EHerbalistState.WAIT_MIXING);
    end;

    if not UseChemNecklace then
      Exit(EHerbalistState.DO_POTIONS);

    if not Self.CheckNecklace then
      Exit(EHerbalistState.OPEN_BANK);

    Exit(EHerbalistState.DO_POTIONS);
  end;
  Self.Mixing := False;

  if Self.BankEmpty and Self.CollectEmpty then
    Exit(EHerbalistState.OUT_OF_SUPPLIES);

  if BankEmpty then
    Exit(EHerbalistState.OPEN_COLLECT);

  Exit(EHerbalistState.OPEN_BANK);
end;

//Function to run before the script shuts down (useful for script chainer).
function THerbalist.Terminate(): Boolean; override;
var
  i: Int32;
  bankItem: TBankItem;
begin
  bankItem := TBankItem.Setup(Self.Potions[0].Item, Bank.QUANTITY_ALL, True);
  Result := inherited;
  if Result then
    for i := 0 to 5 do
      if Result := Bank.WithdrawItem(bankItem, True) then
        Break;
end;

//Main loop of the script.
procedure THerbalist.Run(maxActions: UInt32; maxTime: UInt64);
begin
  Self.Init(maxActions, maxTime);

  repeat
    Self.State := Self.GetState();
    Self.SetAction(ToStr(Self.State));

    case Self.State of
      EHerbalistState.HOVER_BANK: Self.HoverBank();
      EHerbalistState.OPEN_BANK: Banks.WalkOpen();
      EHerbalistState.WITHDRAW_VIALS: Self.Withdraw(Self.Vial);
      EHerbalistState.WITHDRAW_INGREDIENTS: Self.Withdraw(Self.Ingredients);
      EHerbalistState.WITHDRAW_NECKLACE: Self.Withdraw(Necklace);
      EHerbalistState.WEAR_NECKLACE: Self.WearNecklace();
      EHerbalistState.DEPOSIT_POTIONS: Self.Deposit();

      EHerbalistState.OPEN_COLLECT: CollectBoxes.WalkOpen();
      EHerbalistState.HANDLE_COLLECT: Self.HandleCollectBox();
      EHerbalistState.CLOSE_INTERFACE: GameInterface.Close();

      EHerbalistState.DO_POTIONS: Self.DoPotion();
      EHerbalistState.HANDLE_MAKE: Self.HandleMake();
      EHerbalistState.WAIT_MIXING: Self.WaitMixing();

      EHerbalistState.LEVEL_UP: Chat.HandleLevelUp();
      EHerbalistState.CLOSE_CONTEXT: ChooseOption.Close();

      EHerbalistState.OUT_OF_SUPPLIES, EHerbalistState.END_SCRIPT: Break;
    end;

    Self.DoAntiban();
  until Self.ShouldStop();

  if not Self.Terminate() then
    Self.Fatal(Self.Name + ' didn''t terminate properly. Stopping execution.');
end;

var
  Herbalist: THerbalist;

